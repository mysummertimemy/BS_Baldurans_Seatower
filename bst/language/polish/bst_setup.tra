@20 = ~Świątynia Selune~
@21 = ~Koszary~
@22 = ~Płatnerz~
@23 = ~Łuczniczka~
@24 = ~Wieża Morska Baldurana~
@25 = ~Nizioproca~
@26 = ~Lista dzisiejszych wart. Śmiertelne nudy.~
@27 = ~Monumentalny posąg Baldurana. Przypomina bardziej dwuipółmetrowego ogra, który lada moment ma się przewrócić.~
@28 = ~Napis głosi: „Balduran”. W niczym nie przypomina on jednak żadnego z portretów założyciela miasta, jakie kiedykolwiek dane ci było oglądać.~
@29 = ~Stosy kamieni przygotowane do użycia w trebuszach na dachu.~
@30 = ~Właz jest zamknięty.~
@31 = ~Świątynia Ilmatera~
@32 = ~Czytasz stronę. Widnieje na niej: „Jestem wszystkimi barwami i żadną zarazem”.~
@33 = ~Garbarnia~
@34 = ~Katakumby~
