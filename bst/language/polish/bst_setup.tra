// z_quest_rabbits_and_nabassus.d
@4000 = ~Wolny! Nareszcie jestem wolny! Dziękuję wam, moi wybawcy, za uwolnienie mnie spod kontroli tego młodego nabassu. Trafił mnie swoimi Oczami śmierci, gdy tylko weszliśmy z przyjacielem do tych sal, i od tamtej pory byłem zmuszony mu służyć.~
@4001 = ~Klaus wydostał się na zewnątrz, ale... nie sądzę, by miewał się dobrze, skoro macie zwój potrzebny do wejścia do lochów...?~
@4002 = ~Żyje, jeśli o to się martwisz.~
@4003 = ~Kiedy ostatnio go widziałem, był w Wieży Morskiej Baldurana i przywoływał króliki. MNÓSTWO królików.~~Kiedy ostatnio go widziałam, był w Wieży Morskiej Baldurana i przywoływał króliki. MNÓSTWO królików.~
@4004 = ~Oddał mi go dobrowolnie. Choć przy stanie jego umysłu „dobrowolność” to pojęcie względne.~
@4005 = ~I co z tego?~
@4006 = ~Och, więc to o ciebie chodziło temu szalonemu magowi? A ja myślałem, że on chce ratować naszego „gospodarza”, Alguine'a!~~Och, więc to o ciebie chodziło temu szalonemu magowi? A ja myślałam, że on chce ratować naszego „gospodarza”, Alguine'a!~
@4007 = ~Och, niczego nie sugerowałem!~~Och, niczego nie sugerowałam!~
@4008 = ~Naprawdę?~
@4009 = ~*ekhm* Króliki?...~
@4010 = ~Po prostu łudziłem się, że... cóż, że spróbuje mi jakoś pomóc. To wszystko.~
@4011 = ~Robił to. Uwierz mi, że to robił.~
@4012 = ~Cóż – oto jesteśmy, no nie?~
@4013 = ~Może nie szło mu to najlepiej, ale widać było, że się stara.~
@4014 = ~Dlaczego sam go nie odszukasz i się nie przekonasz?~
@4015 = ~Ach! Och! Rozumiem!~
@4016 = ~Muszę go znaleźć i sprawdzić, jak się miewa. Biedaczysko, musi być naprawdę zdesperowany... Dziękuję wam, moi wybawcy. Nie mam przy sobie nic, co mogłoby wam się przydać, ale przy naszym następnym spotkaniu będę miał dla was coś gotowego!~
@4017 = ~Szalony mag? Mówisz przypadkiem o Klausie?~
@4018 = ~Chyba tak się nazywał. Szukał kogoś wystarczająco silnego, by „go” uratować. Więc zgaduję, że miał na myśli ciebie?~
@4019 = ~Szczury! Wszędzie są szczury! Przysięgam, że widziałem szczury biegające na górze. Tu jest tak brudno!~
@4020 = ~Nie otwieraj tych drzwi! Znowu to robi. Ten człowiek jest SZALONY!~
@4021 = ~Muszę przywołać te właściwe. Właściwe go uwolnią! Właściwe zabiją bestię. Właściwe...~
@4022 = ~To nie te! Nigdy nie te... Ja... nigdy go nie uratuję... Nigdy...~
@4023 = ~O nie, panie Klaus! Pamiętasz pan, co było mówione, nie? Muszę pana wyprosić z gospody... Bardzo mi przykro, musisz mi pan uwierzyć!~
@4024 = ~No już, weź pan rzeczy – zostaw pan te króliki, zaraz je wyłapię – i chodź pan za mną, proszę...~
@4025 = ~Teraz mogę przywołać te właściwe! Chcesz zobaczyć?~
@4026 = ~Ach, tu jesteś. Co chcesz mi pokazać?~
@4027 = ~Co masz na myśli? Możesz teraz przywoływać brązowe króliki?~
@4028 = ~Daj mi spokój. Dopiero co uganiałem się za tymi twoimi durnymi królikami po całej gospodzie, mam ich powyżej uszu.~~Daj mi spokój. Dopiero co uganiałam się za tymi twoimi durnymi królikami po całej gospodzie, mam ich powyżej uszu.~
@4029 = ~Nawet nie próbuj przywoływać kolejnego królika w mojej obecności.~
@4030 = ~Ale... teraz to te właściwe! Na pewno! Muszę komuś pokazać, inaczej nie będę miał pewności!~
@4031 = ~A teraz mogę ci pokazać?~
@4032 = ~Owszem. Teraz mam czas.~
@4033 = ~*wzdycha* Dobra, pokazuj.~
@4034 = ~Nie.~
@4035 = ~Nie, kolor nie ma znaczenia.~
@4036 = ~Chodzi o zęby! Spójrz na zęby!~
@4037 = ~Muszę to sprawdzić... te właściwe!~
@4038 = ~Nie! NIE!! Martwy! On jest martwy... Nie jest dość silny... Nigdy nie będzie dość silny...~
@4039 = ~Ale TY jesteś! Jesteś wystarczająco silny! Weź to i idź do środka. Przeznaczenie tego chce! Przeznaczenie! Tak! I ratuj go... Proszę, ratuj go...~ ~Ale TY jesteś! Jesteś wystarczająco silna! Weź to i idź do środka. Przeznaczenie tego chce! Przeznaczenie! Tak! I ratuj go... Proszę, ratuj go...~
@4040 = ~Pomoc twojemu przyjacielowi to dla mnie zaszczyt.~
@4041 = ~Ekhm, słucham?~
@4042 = ~Rozmawiamy o człowieku, tak? Nie o króliku? A zwłaszcza nie o tym ostatnim monstrum, co?~
@4043 = ~Lochy do zbadania? Jasne, czemu nie.~
@4044 = ~Przestań mi wpychać te brudne zwoje za pas!~
@4045 = ~On jest w ruinach, tych starych ruinach w Kniei Ostrych Zębów! Jest uwięziony!~
@4046 = ~Na imię Selune, co to u licha było?! Mamy dość problemów z tępieniem maszkaronów, które bezczeszczą domeny naszej bogini. Nie potrzeba nam jeszcze do tego nowych odmian nieumarłych!~
@4047 = ~Stawiam na to, że to był wampiryczny królik.~
@4048 = ~No, pięknie. A gdzieście wszyscy byli, kiedy walczyłem z tym nieumarłym królikiem?~~No, pięknie. A gdzieście wszyscy byli, kiedy walczyłam z tym nieumarłym królikiem?~
@4049 = ~Przyszłam tak szybko, jak tylko mogłam. Narobiliście wystarczająco dużo hałasu.~
@4050 = ~No dobrze, co mamy zrobić z tym biednym głupcem?!~
@4051 = ~Ten człowiek jest bardzo udręczony, kapłanko Selune. My, mnisi Ilmatera, zaopiekujemy się nim i damy mu schronienie, aż jego skołatany umysł znów się uspokoi.~
@4052 = ~Phi, róbcie jak chcecie. Ale gwarantuję wam, że nie usłyszymy waszych krzyków, jeśli ten szaleniec nadal będzie przywoływał wampiryczne króliki wewnątrz klasztoru. *parska*~
@4053 = ~Tak bardzo wam dziękuję za pomoc!~
@4054 = ~Ratuj go... muszę znaleźć sposób, jakiś sposób...~
@4055 = ~Udało wam się! Przeżyliście!~
@4056 = ~Och! Spójrz tylko, Klausie! To poszukiwacze przygód, którzy mnie uratowali! Witajcie! Witajcie, moi przyjaciele.~
@4057 = ~Ja... dziękuję wam za uratowanie mojego przyjaciela.~
@4058 = ~Obiecałem, że przy następnym spotkaniu będę miał dla was nagrodę. Pozwólcie, że szybko ją przyniosę.~
@4059 = ~Nie martw się o nagrodę.~
@4060 = ~Dobrze was widzieć w dobrym zdrowiu.~
@4061 = ~No, najwyższy czas!~
@4062 = ~Słucham? Och, nie, nie, nie.~
@4063 = ~Zasługujecie na nagrodę i z radością wam ją wręczymy za to, co zrobiliście.~
@4064 = ~To, co dla nas zrobiliście, było co najmniej szlachetne. Proszę, mam nadzieję, że to się wam przyda. Powiem jedno – wyprawa do lochów w grupie złożonej z zaledwie dwóch magów to fatalny pomysł. Naprawdę fatalny.~
@4065 = ~To znaczy... dla nas taki był. Heh.~
@4066 = ~Nie chcę brzmieć niewdzięcznie, ale Klaus jest w bardzo złym stanie i wkrótce będzie musiał znów odpocząć.~
@4067 = ~Macie jeszcze jakieś pytania?~
@4068 = ~Możesz mi powiedzieć coś o tych lochach?~
@4069 = ~Dobra, nie wytrzymam. DLACZEGO KRÓLIKI?~
@4070 = ~Nie mam więcej pytań. Mam nadzieję, że dojdziecie do siebie.~
@4071 = ~Zostawię was zatem samych.~


@4072 = ~Tak, Labirynt Wspomnień Przyszłości. Przeczytaliśmy o nim w pewnej prastarej księdze, a niedługo potem odkryliśmy zwój Almirana. Nie wiemy o nim zbyt wiele, zachowało się tylko kilka wzmianek – głównie opisy osób, które znalazły wejście i weszły do środka. A przynajmniej tych, które wyszły stamtąd przy zdrowych zmysłach, bo bywało z tym różnie. Almiran, mag z Thay, był pierwszym, któremu udało się odnaleźć bezpośrednie wejście i ustabilizować je za pomocą swojego zwoju. Co się z nim stało? Tego nie wiemy.~
@4073 = ~Wygląda na to, że tylko posiadacz zwoju ujrzy „wspomnienia z przyszłości” swojego życia. Nie wiedzieliśmy o tym, kiedy go zdobywaliśmy. W naszym przypadku padło na Klausa, a ja po prostu poszedłem za nim i patrzyłem na jego cierpienie...~
@4074 = ~Nie... nie chciałem. Celowałem w coś większego... ale bałem się przywołać cokolwiek innego.~
@4075 = ~Biedny Klaus ma koncentrację małego dziecka od czasu walki z nabassu, a lochy pewnie tylko to pogorszyły. Jak już mówiłem, doceniamy waszą pomoc – we wszystkim.~
@4076 = ~Nasza szczera wdzięczność będzie ci towarzyszyć, przyjacielu. Bardzo nam przykro, że wpakowaliśmy was w takie kłopoty.~ ~Nasza szczera wdzięczność będzie ci towarzyszyć, przyjaciółko. Bardzo nam przykro, że wpakowaliśmy was w takie kłopoty.~
@4077 = ~Naprawdę mi przykro... nie wiedziałem, jak inaczej pomóc Ulfowi...~
@4078 = ~Klausie, nie przemęczaj się. Chodź, usiądź na chwilę.~
@4079 = ~To nie tak. To ty przez te wszystkie miesiące byłeś ghastem... Powinienem się tobą opiekować, a nie na odwrót...~
@4080 = ~Nonsens. Czuję się jak nowo narodzony. To ty cały ten czas zamartwiałeś się i szukałeś pomocy, a te lochy zupełnie cię osłabiły. Masz, weź ten koc... Chcesz się czegoś napić? Mogę poprosić kucharkę o trochę tego jej wybornego wywaru...~
@4081 = ~Zawsze będziesz tu mile widzianym gościem, przyjacielu.~
@4082 = ~*Złapanie królika nie sprawia trudności. Możesz go wziąć – ale po co ci wierzgający królik w plecaku?*~
@4083 = ~*Złapanie królika nie sprawia trudności*.~
@4084 = ~*Podnosisz go*.~
@4085 = ~*Puszczasz go wolno*.~
@4086 = ~*Królik odskakuje*.~
@4087 = ~*Wkładasz go do klatki*.~


// z_roryn_ratquest.d
@4100 = ~Witajcie w Gospodzie Wieży Morskiej. Znajdzie się jedzenie i pokoje dla tych, których na nie stać. Jestem tutejszym gospodarzem, Roryn się nazywam.~
@4101 = ~Bardzo przepraszam za te kłopoty i te wszystkie króliki na górze.~
@4102 = ~W czym mogę służyć?~
@4103 = ~Pokaż mi, co masz na sprzedaż.~
@4104 = ~Jesteś krasnoludem! Właśnie rozmawiałem z kucharką o tym, co sądzi o twojej rasie...~~Jesteś krasnoludem! Właśnie rozmawiałam z kucharką o tym, co sądzi o twojej rasie...~
@4105 = ~W sprawie tych królików...~
@4106 = ~Jednak nie będę szukać twoich szczurów.~
@4107 = ~Mam pewne podejrzenia co do szczurów na piętrze. Nocuje tu teraz jakieś dziecko?~
@4108 = ~Twoja córka, Azala... Czy ona ma jakieś zwierzątko?~
@4109 = ~Znalazłem szczura na piętrze...~~Znalazłam szczura na piętrze...~
@4110 = ~Jak się miewa Azala?~
@4111 = ~To wszystko, bywaj.~
@4112 = ~Ach, cóż, to dobra z niej dusza. Świetnie się dogadujemy – dopóki nie wchodzę jej do kuchni.~
@4113 = ~Ale po co było zabijać królika na czystej podłodze? Ach, muszę to zaraz wytrzeć, bo zostanie plama. Tym razem nic wam nie policzę, ale proszę, nie brudźcie mi już więcej w Wieży!~
@4114 = ~Poślę Barneya, żeby zaraz się tym zajął i po całym incydencie nie będzie śladu. No, przynajmniej jak już wyszoruje podłogi.~
@4115 = ~O co chodziło z tym magiem? Wyglądał na zdesperowanego.~
@4116 = ~Mam nadzieję, że taka zwierzęca plaga w pokojach więcej się nie powtórzy!~
@4117 = ~Tak zrób, dobry człowieku.~
@4118 = ~Bywajcie i miłego pobytu w Gospodzie Wieży Morskiej!~
@4119 = ~Och, ja też, uwierzcie mi!~
@4120 = ~Może pomogę ci wyłapać te króliki?~
@4121 = ~Cóż, zostawię cię z tym łapaniem królików.~
@4122 = ~Ach, to pan Klaus. Przybył tu kilka miesięcy temu, został uwięziony, kiedy podnieśli mosty. Zawsze sprawiał wrażenie strasznie przelęknionego, jeśli chcecie znać moje zdanie. Ciągle gada o jakimś „Ulfie” i że musi go ratować.~
@4123 = ~Ulf? To jego przyjaciel?~
@4124 = ~Dlaczego akurat króliki?~
@4125 = ~Tak sądzę, ale nigdy nie powiedział nic więcej. Nie zawsze myślał trzeźwo, jeśli wiecie, co mam na myśli.~
@4126 = ~Jestem prawie pewien, że próbował przywołać coś innego, ale nie mógł się dość skoncentrować. No, ale dopóki to był króliczek czy dwa, nie było powodu, by wyrzucać go z gospody.~
@4127 = ~Och! To by była doprawdy wielka pomoc. Barney ma wciąż sporo roboty na zewnątrz. Masz tu klatkę, do której możesz je wkładać. Dam wam 50 sztuk złota za każdego z tych małych kicusiów, co?~
@4128 = ~Co z nimi?~
@4129 = ~Skończyłem już zbieranie.~~Skończyłam już zbieranie.~
@4130 = ~Nie będę już łapać królików. Oto twoja klatka.~
@4131 = ~Jednak ich nie połapię.~
@4132 = ~Jak myślisz, ile ich tam jest?~
@4133 = ~Wracam do uganiania się za nimi.~
@4134 = ~Tak zrób! Barney już się cieszy na myśl o sprzątaniu bobków.~
@4135 = ~Rozumiem. No nic, dzięki i tak!~
@4136 = ~No, to ile ich masz?~


@4137 = ~Widzę tylko jednego. Masz tu 50 sztuk złota!~
@4138 = ~Widzę tylko dwa. Proszę, 100 sztuk złota dla was!~
@4139 = ~Jeden, dwa...~
@4140 = ~...trzy! To daje 150 sztuk złota.~
@4141 = ~...cztery! To daje 200 sztuk złota.~
@4142 = ~...pięć! To daje 250 sztuk złota.~
@4143 = ~...sześć! To daje 300 sztuk złota.~
@4144 = ~...siedem! To daje 350 sztuk złota.~
@4145 = ~...osiem! To daje 400 sztuk złota.~
@4146 = ~...dziewięć! To daje 450 sztuk złota.~
@4147 = ~...dziesięć! To daje 500 sztuk złota.~
@4148 = ~...jedenaście! To daje 550 sztuk złota.~
@4149 = ~Oto wasze złoto. Dzięki za pomoc!~
@4150 = ~Ooooch, jaki słodziak! Mogę go pogłaskać?~
@4151 = ~Mała, nie teraz... Muszę je jak najszybciej wynieść z gospody.~
@4152 = ~Cóż, powiedziałbym, że jest ich co najmniej dziesięć.~
@4153 = ~Hejka!~
@4154 = ~To moja mała Azala.~
@4155 = ~Moja córka. Moja pozostała dwójka jest chora, a żona, Dorna, ma ręce pełne roboty przy ich pielęgnacji, więc wziąłem małą ze sobą do pracy. Mam nadzieję, że nic nie nabroiła; zazwyczaj jest cicha i nie sprawia żadnych kłopotów.~
@4156 = ~Szczur! Widziałam szczura na górze!~
@4157 = ~Pani, bardzo przepraszam za niedogodności. Z pewnością widziała pani jednego z tych królików, które wypuszczono w budynku, ale sytuacja jest już...~
@4158 = ~WYPRASZAM SOBIE! Sądzi pan, że nie odróżnię szczura od KRÓLIKA? Mówię panu, widziałam SZCZURA na drugim piętrze tego przybytku.~
@4159 = ~Na drugim piętrze? Hm, dziękuję bardzo, miłościwa pani. Rano w piwnicy nie było żadnych szczurów, ale skoro gość zgłasza ich obecność, muszę tam natychmiast posłać Barneya.~
@4160 = ~To przypomina mi dawne czasy... Mogę zabić te szczury za ciebie.~
@4161 = ~Cóż, nie chcę mieć z tym nic wspólnego. Powodzenia.~
@4162 = ~Dobrze cię rozumiem. Hej, Barney, bierz pałkę, zapasowe pułapki i idź walczyć z tymi bestiami!~
@4163 = ~Azala, mama przysłała wiadomość. Nie wyglądasz najlepiej, wracaj do domu.~
@4164 = ~Jestem pewna, że to królik. Musicie szukać KRÓLIKA i... i przynieść go do mnie!~
@4165 = ~Może i tak, mała, ale jeśli to faktycznie szczury, a nie jeden z tych kicusiów, co to polazł na schody, musimy się tym szybko zająć. Słuchajcie, Barney wciąż sprząta na górze królicze bobki. Jeśli wejdziecie na piętro i sprawdzicie, co tam jest – dam wam 50 sztuk złota za każdego szczura, którego dopadniecie przed Barneyem. Jeśli to królik, dajcie mu kicać, Barney zajmie się nim później. Szczury są ważniejsze. I proszę... bądźcie przy tym tak dyskretni, jak to tylko możliwe...~
@4166 = ~Nie, Azala, nie ty. Zostań z tatusiem, proszę.~
@4167 = ~Heh, tak, chyba pamiętam plagę szczurów u starego Reevora. Zrzędził na wasze „marne” postępy tak głośno, że połowa Candlekeep go słyszała.~
@4168 = ~Niektóre rzeczy po prostu t-trzeba zrobić.~
@4169 = ~Szczury nie powinny gnieździć się w domach, bo zagrażają zdrowiu mieszkańców. Wyświadczymy przysługę, pozbywając się ich.~
@4170 = ~Nawet w najmniejszym zleceniu kryje się honor.~
@4171 = ~Tak, myślę, że można to uznać za honorowe zadanie.~
@4172 = ~Sądzę jednak, że lepiej spożytkujemy nasz czas gdzie indziej.~
@4173 = ~JA nie dotknę żadnego SZCZURA!~
@4174 = ~Minsc nie jest tego taki pewien. To małe, futrzaste zwierzątka, zupełnie jak Boo...~
@4175 = ~*piszczy*~ [GAM_48]
@4176 = ~O, Boo ma rację. Boo nie załatwia się do jedzenia, które ma <CHARNAME>. No i nie ma ogona!~
@4177 = ~To MUSI być jakiś żart.~
@4178 = ~Ach, tak, szczury. Zawsze sprawiają kłopoty, zarówno w sklepie, jak i w gospodzie.~
@4179 = ~Mamy marnować naszą potęgę na robactwo? Dlaczego nie wybijemy wszystkich w tej gospodzie, zaczynając od tej sali?!~
@4180 = ~*Szczur wygląda na... lśniącego, jakby był umyty i wyczesany. Jest też niezwykle tłusty. Przyglądając się bliżej, dostrzegasz maleńką kokardkę z różowej wstążki na jego ogonie*.~
@4181 = ~*Szczur jest dość powolny. Możesz go złapać i zabrać ze sobą*.~
@4182 = ~*Złap szczura*.~
@4183 = ~*Pozwalasz mu uciec*.~
@4184 = ~*Zabijasz szczura*.~
@4185 = ~*Z cichym piskiem szczur odwraca się*.~
@4186 = ~*Chowasz szczura do jednej ze swoich kieszeni*.~
@4187 = ~Oooch, spójrzcie na te małe wibrysy! I ta wstążeczka! Ona jest taka słodka!~
@4188 = ~Myślę, że ten szczur n-należy do jakiegoś dziecka – patrzcie na tę wstążkę na ogonie.~
@4189 = ~Podoba mi się pomysł posiadania małego, futrzastego szczura jako zwierzątka. Choć ten wydaje się należeć do kogoś innego.~
@4190 = ~KTO brałby SZCZURA za zwierzątko domowe?! Ohyda!~
@4191 = ~Kręci się tu mnóstwo dam z potomstwem. Kto wie, co te rozpieszczone bachory robią dla zabicia czasu.~
@4192 = ~Och, chcesz powiedzieć, że robią to, by zezłościć nianię? Hm... Ale SZCZUR? Fuj!~
@4193 = ~Może Minsc weźmie tego, a ja dostanę Boo?~
@4194 = ~Prędzej mi kaktus na dłoni wyrośnie, niż oddam Boo!~
@4195 = ~<CHARNAME> musi się zaopiekować piszczącym towarzyszem i oddać go właścicielowi, kimkolwiek on jest!~
@4196 = ~Jesteś pewien, że masz przy sobie dość ziarna? Te maluchy lubią jeść.~~Jesteś pewna, że masz przy sobie dość ziarna? Te maluchy lubią jeść.~
@4197 = ~Garricku, to zwierzę nie wygląda na zagłodzone. Jestem pewna, że przez jakiś czas poradzi sobie bez jedzenia. Przynajmniej dopóki <CHARNAME> nie zwróci go „właścicielowi”.~
@4198 = ~Powinniśmy szybko znaleźć tego, kto przyznaje się do tego stworzenia. I tak zmarnowaliśmy już dość czasu.~
@4199 = ~A może by go tak upiec i wepchnąć „właścicielowi” do gardła? Co za strata czasu.~
@4200 = ~A może by go tak upiec i samemu zjeść smaczniejsze kąski, zanim oddamy go „właścicielowi”? Nie ma co marnować jedzenia.~
@4201 = ~Oswojony szczur w gospodzie... To może być naprawdę zabawne. Przynajmniej jeśli ja będę miał w tej sprawie coś do powiedzenia.~
@4202 = ~Różowa wstążka? Wyczesane futerko? Stawiam całe złoto, które ma przy sobie <CHARNAME>, że należy do jakiejś dziewczynki.~
@4203 = ~*Zabijasz szczura jednym uderzeniem broni i zabierasz truchło ze sobą*.~
@4204 = ~Ojej, spójrzcie na tę wstążkę! Wygląda jak te, które zawsze wiązałam Panu Pacynce. <CHARNAME> – myślę, że właśnie kogoś bardzo unieszczęśliwiłeś.~~Ojej, spójrzcie na tę wstążkę! Wygląda jak te, które zawsze wiązałam Panu Pacynce. <CHARNAME> – myślę, że właśnie kogoś bardzo unieszczęśliwiłaś.~
@4205 = ~Myślę, że ten szczur n-należał do dziecka – patrzcie na tę wstążkę na ogonie.~
@4206 = ~Co? Cóż, w głównej sali jest kilkoro dzieci, ale żadne z nich nie nocuje obecnie w pokojach, więc... Och, no i jest jeszcze moja mała Azala, przynajmniej dzisiaj.~
@4207 = ~Zobaczymy. Przyniosę ci każdego szczura, którego znajdę.~
@4208 = ~Nie, ale zabawne, że pytasz – marudziła o jakiegoś od tygodni.~
@4209 = ~Będę na to czekać – no, może nie „czekać” z radością, ale wiesz, co mam na myśli.~
@4210 = ~Dobrze! Tylko jeden? Och... on ma różową wstążkę na ogonie?!~
@4211 = ~*krzyczy* Co?!~
@4212 = ~Co się stało, Azalo?~
@4213 = ~Ona, ona naprawdę nie żyje?~
@4214 = ~O czym ty mówisz, mała?~
@4215 = ~*łka* Ten szczur to była moja Betsy *łka*. Znalazłam ją na ulicy w zeszły piątek i opiekowałam się nią, i nie chciałam zostawiać jej samej w domu, więc wzięłam ją ze sobą, i pozwalałam jej biegać, ale tylko jak nie była głodna, i sprzątałam po niej, i przepraszam, że ta pani ją widziała, i nie powinnam pozwalać jej biegać, ale mi uciekła, i miałam nadzieję, że nikt jej nie zauważy, a potem kazałeś mi być blisko i nie mogłam iść jej szukać, a potem te wszystkie króliki mnie rozproszyły i... *bierze wdech*~
@4216 = ~Przyniosłaś SZCZURA do pokojów gościnnych? W mojej gospodzie? Azalo, masz ty pojęcie, co narobiłaś?~
@4217 = ~Betsy nie żyje, przyznaję. Azalo, bardzo mi przykro.~
@4218 = ~Oto twój szczur. Może ktoś zabrać ode mnie to truchło?~
@4219 = ~Ona żyje, Azalo.~
@4220 = ~Ciii, Azalo. Mam ją tutaj, widzisz?~
@4221 = ~Doprawdy? Dopiero co przedzierałem się przez dziesiątkę królików na górze, a teraz się okazuje, że dziecko tak desperacko pragnie zwierzątka, że oswaja SZCZURA?~~Doprawdy? Dopiero co przedzierałam się przez dziesiątkę królików na górze, a teraz się okazuje, że dziecko tak desperacko pragnie zwierzątka, że oswaja SZCZURA?~
@4222 = ~Nieważne – uciszy ktoś to dziecko?~
@4223 = ~Och. Przykro mi z powodu tego całego zamieszania!~
@4224 = ~*zawodzi*~
@4225 = ~Betsy! Ona żyje! Och, tak strasznie się bałam, że ją zabiłeś! Dziękuję! Dziękuję!~~Betsy! Ona żyje! Och, tak strasznie się bałam, że ją zabiłaś! Dziękuję! Dziękuję!~
@4226 = ~Azalo, mama przysłała wiadomość. Wracaj do domu. Zabierz tego szczura, a później o tym porozmawiamy.~
@4227 = ~Cóż, nie tego się spodziewałem, ale dopadliście jednego szczura. Oto wasze 50 sztuk złota.~
@4228 = ~Dzięki za pomoc, choć nikt nie przypuszczał, że tak to się skończy. Miłego pobytu w Gospodzie Wieży Morskiej. Jeśli kiedyś przyjdzie wam uganiać się za kolejnym gryzoniem po pokojach, stawiam kolejkę, słowo daję!~
@4229 = ~Dzięki, że pytasz. Nie martwcie się o nią. Dostanie królika. Ale nie białego, mam ich już powyżej dziurek w nosie! Ten szczur i tak nam nie pasował. Są granice dobrego smaku, jak sami dobrze wiecie. Żal mi jej było, bo tak go lubiła, ale tak będzie lepiej.~

// z_well_encounter.d
@4240 = ~Studnia w Wieży. Z powodu bliskości morza woda jest dość słonawa, ale nadaje się do celów gospodarczych i podlewania terenów uprawnych.~
@4241 = ~*Używasz studni, aby napełnić beczkę wodą*.~
@4242 = ~*Wpuszczasz beczkę z żywiołakiem ognia do studni*.~
@4243 = ~*Próbujesz łyka wody ze studni*.~
@4244 = ~*Wrzucasz do studni złotą monetę, zgodnie z tradycją wypowiadania życzeń*.~
@4245 = ~*Wrzucasz do studni kolejną złotą monetę, zgodnie z tradycją wypowiadania życzeń*.~
@4246 = ~*Rzucasz kamyk do studni.*~
@4247 = ~*Rzucasz kolejny kamyk do studni*.~
@4248 = ~*Rzucasz dziesiąty kamyk do studni*.~
@4249 = ~*Zostawiasz studnię w spokoju*.~
@4250 = ~*Beczka unosi się na powierzchni wody, powoli tonąc w miarę jak woda dostaje się do środka*.~
@4251 = ~*Wyciągasz beczkę z powrotem*.~
@4252 = ~*Patrzysz, jak beczka całkowicie napełnia się wodą, topiąc żywiołaka ognia*.~
@4253 = ~*Beczka jest już pełna wody. Żywiołak ognia zginął*.~
@4254 = ~*Beczka jest już pełna wody*.~
@4255 = ~*Woda smakuje słono i nieco stęchlizną, ale i tak jest lepsza niż ta, którą piłeś na szlaku*.~~*Woda smakuje słono i nieco stęchlizną, ale i tak jest lepsza niż ta, którą piłaś na szlaku*.~
@4256 = ~*Moneta uderza o powierzchnię z wyraźnym pluskiem, po czym znika w toni*.~
@4257 = ~Och, <CHARNAME>! Ja też chcę to zrobić! O czym pomyślałeś? Czekaj! Nie mów mi, bo się nie spełni. Proszę! I już jej nie ma. Chciałabym mieć ładny, wygodny dom w niezbyt dużym mieście, ze służbą i KOTEM tylko dla mnie... nie, to znaczy, wcale o tym NIE pomyślę, bo przecież nie wolno wypowiadać życzeń na głos!~~Och, <CHARNAME>! Ja też chcę to zrobić! O czym pomyślałaś,? Czekaj! Nie mów mi, bo się nie spełni. Proszę! I już jej nie ma. Chciałabym mieć ładny, wygodny dom w niezbyt dużym mieście, ze służbą i KOTEM tylko dla mnie... nie, to znaczy, wcale o tym NIE pomyślę, bo przecież nie wolno wypowiadać życzeń na głos!~
@4258 = ~Ja też, ja też! *Alora głośno wciąga powietrze, trzymając monetę w dłoni*. No, leć. Przynieś mi szczęście!~
@4259 = ~*Ta moneta również wydaje wyraźny plusk przy uderzeniu o powierzchnię wody, po czym koziołkuje w toni, znikając z oczu*.~
@4260 = ~Doprawdy nie wiem, co starasz się tym osiągnąć, <CHARNAME>. Powiedz mi, proszę, że nie wierzysz w studnie spełniające życzenia.~
@4261 = ~<CHARNAME>! Uzbrój się w cierpliwość! Nie spełni się szybciej, jeśli będziesz rzucać monetami co chwilę. Chociaż... to naprawdę niezła zabawa. *chichocze* Iii... hop!~
@4262 = ~*wzdycha*~
@4263 = ~Lepiej nie karćmy kogoś takiego jak <CHARNAME> – i tak ma w swym życiu aż nadto trosk, a tak mało przyjemności.~
@4264 = ~Wiesz, że za każdym razem muszę się powstrzymywać, żeby nie zrobić tego samego? Jestem z siebie taaaka duuumna, że nie wrzuciłam całej sakiewki!~
@4265 = ~Minsc nie rozumie, dlaczego <CHARNAME> chce płukać te wszystkie złote monety w studni... Co, Boo? Ach! Rozumiem. <CHARNAME> ukrywa je tam na później. Bardzo sprytne!~
@4266 = ~Jeśli ktokolwiek rozważa wrzucenie całego naszego złota do tej studni, niech ma pewność, że osobiście go tam po nie poślę.~
@4267 = ~Jeśli ktoś choć pomyśli o wrzuceniu naszego złota do tej studni, zginie z mojej ręki.~
@4268 = ~To byłoby doprawdy wielkie marnotrawstwo, Imoen. Nigdy nie wiem, kiedy mówisz żartem, a kiedy...~
@4269 = ~...kiedy zamierzam zrobić coś kompletnie głupiego? Ach, Ajantisie!...~
@4270 = ~Bez obaw. NIGDY nie wrzuciłabym własnej sakiewki!...~
@4271 = ~Kamień z serca. Dobrze to słyszeć.~
@4272 = ~Wrzuciłabym czyjąś, to oczywiste! *chichocze*~
@4273 = ~<CHARNAME>, gdybym wiedziała, że tak łatwo rozstajesz się ze złotem, nie spędzałabym tyle czasu na przeszukiwaniu cudzych kieszeni. *chichocze* Ale nie daj sobie popsuć zabawy!~
@4274 = ~Gdybym wiedział, że tak łatwo szafujesz złotem, nie łączyłbym z tobą sił, <CHARNAME>. Skończyliśmy JUŻ tutaj?!~
@4275 = ~Wiem, że sama to przed chwilą zrobiłam, ale... Wyobrażenie tych wszystkich monet na dnie zimnej, ciemnej wody – leżących tam przez TYSIĄCLECIA, nim znów ktoś je wypoleruje – jest dość przygnębiające... Muszę się skupić na życzeniach! Życzenia. <CHARNAME>! Mam nadzieję, że pomyślałeś o czymś wspaniałym!~~Wiem, że sama to przed chwilą zrobiłam, ale... Wyobrażenie tych wszystkich monet na dnie zimnej, ciemnej wody – leżących tam przez TYSIĄCLECIA, nim znów ktoś je wypoleruje – jest dość przygnębiające... Muszę się skupić na życzeniach! Życzenia. <CHARNAME>! Mam nadzieję, że pomyślałaś o czymś wspaniałym!~
@4276 = ~Nie wiem, o co tam prosisz, chłopcze, ale jestem całkiem pewien, że powtarzanie tego w kółko nie sprawi, że życzenie prędzej się spełni.~
@4277 = ~Nie wiem, o co tam prosisz, dziewczyno, ale jestem całkiem pewien, że powtarzanie tego w kółko nie sprawi, że życzenie prędzej się spełni.~
@4278 = ~Nie w-wiem, o czym marzysz, <CHARNAME>, ale mam szczerą nadzieję, że jest to warte tego złota.~
@4279 = ~Nie ma takiego życzenia, które usprawiedliwiałoby wyrzucanie złota w ten sposób.~
@4280 = ~Głupie wierzenia. Złoto lepiej wydać na ekwipunek potrzebny do naszych zadań.~
@4281 = ~Nie będę się rozwodzić nad tym, dlaczego ludzka tradycja wrzucania złota do studni jest kompletnie niedorzeczna – i na dodatek daremna.~
@4282 = ~Następnym razem, gdy poczujesz chęć wyrzucenia złotych monet, po prostu oddaj je mi. Ja też potrafię spełniać sny – przynajmniej tak „dobrze” jak ta studnia.~
@4283 = ~Następnym razem, gdy poczujesz chęć wyrzucenia złota, po prostu włóż je do mojej sakiewki, <CHARNAME>!~
@4284 = ~Cóż za malowniczy widok – <CHARNAME> stoi przy studni Wieży Morskiej, marząc o swych najskrytszych pragnieniach... Zrobisz to jeszcze raz, proszę? Muszę uchwycić ten nastrój...~
@4285 = ~Jak możesz marnować złoto na tak dziecinne zabawy? W mieście są o wiele lepsze sposoby na wydawanie pieniędzy.~
@4286 = ~Zdaje się, że jesteś jedyną osobą próbującą kusić „ducha studni” złotem zamiast kamykami, <CHARNAME>. (Głupie zachowanie. Chyba powinienem być wdzięczny, że wrzuca tylko po jednej monecie naraz).~
@4287 = ~Pewnego dnia znajdą w tej studni jakiegoś utopionego głupca, którego skusiło złoto leżące na dnie.~
@4288 = ~*Po stosunkowo krótkim czasie słyszysz „plusk”, gdy kamyk uderza o powierzchnię wody*.~
@4289 = ~*Ponownie słyszysz „plusk”, gdy kamyk uderza o powierzchnię wody*.~
@4290 = ~*Oczekiwany plusk zostaje zagłuszony przez gniewny syk utopionego ducha, którego spokój zakłóciłeś!*~~*Oczekiwany plusk zostaje zagłuszony przez gniewny syk utopionego ducha, którego spokój zakłóciłaś!*~
@4291 = ~Lubimy przychodzić do Wieży. Dzieci lubią zwierzęta, a tutaj jest bezpiecznie.~
@4292 = ~Zostawię sobie trochę chleba i później nakarmię mewy!~
@4293 = ~Chcę później iść pogłaskać krowy!~


// z_quest_missingmonk.d
@4300 = ~Wyglądasz na osobę, która sporo podróżuje! Potrzebuję kogoś, kto przeprowadziłby dla mnie małe śledztwo. Moja... moja ukochana zaginęła, a ja nie mogę opuścić posterunku. Czy zechcesz jej poszukać? To niedaleko – wystarczy rozejrzeć się na północnym wschodzie miasta i zapytać, czy ktoś wie, dokąd się udała.~
@4301 = ~Powiedz mi coś więcej.~
@4302 = ~Nie, nie mam na to czasu.~
@4303 = ~Jesteś pewien? Mógłbyś po prostu o nią zapytać, kiedy będziesz w pobliżu kapliczki Ilmatera niedaleko Spłonionej Syreny.~~Jesteś pewna? Mogłabyś po prostu o nią zapytać, kiedy będziesz w pobliżu kapliczki Ilmatera niedaleko Spłonionej Syreny.~
@4304 = ~Dobra, powiedz mi coś więcej.~
@4305 = ~Spłoniona Syrena? Cóż, jeśli nagroda pozwoli mi przy okazji na wizytę w środku – to czemu nie.~
@4306 = ~Powiedziałem: nie. Musisz poszukać kogoś innego.~~Powiedziałam: nie. Musisz poszukać kogoś innego.~
@4307 = ~Niech to. Pewnie to nic ważnego, na pewno jak zwykle pomaga gdzieś biednym. Cóż, muszę wracać do obchodu.~
@4308 = ~Och, zdaje się, że dowódca Wieży Morskiej cię szuka, <CHARNAME>. Chodzi o jednego z więźniów, który chce z tobą rozmawiać. Najlepiej udaj się do biura dowódcy na drugim piętrze Wieży.~
@4309 = ~Ma na imię Martina i jest mniszką w tutejszym klasztorze Ilmatera. Widzisz... kapitan nie pochwala zażyłości między personelem Wieży. To nie jest wbrew oficjalnym zasadom, ale wszyscy wiemy, że nie znosi on spoufalania się podwładnych. Dlatego muszę trzymać to w tajemnicy... Zgłosiłem już jej zaginięcie i dowódca wysłał jednego z moich towarzyszy na poszukiwania, więc zrobiłem już wszystko, co mogłem bez dezerterowania z posterunku. Potrzebuję kogoś z zewnątrz.~
@4310 = ~Podobno widziano Martinę w kapliczce Ilmatera w północno-wschodnich Wrotach Baldura, zanim stamtąd odeszła, ale to było ponad dwa tygodnie temu! Opat uważa, że to nic nadzwyczajnego i nie widzi potrzeby wysyłania kolejnej grupy poszukiwawczej. Wiem, że Martina pomaga biednym, gdziekolwiek ich spotka, a jej obowiązki mniszki Ilmatera oznaczają, że zostanie tam, gdzie widzi potrzebujących. To nie pierwszy raz, kiedy znika na całe tygodnie bez słowa. Ale tym razem minęło zbyt dużo czasu bez żadnej wiadomości dla mnie, a to do niej niepodobne.~
@4311 = ~Desperacko potrzebuję jakichś wieści. Gdybyś po prostu udał się do kapliczki Ilmatera na północnym wschodzie miasta i zapytał o miejsce jej pobytu oraz o to, czy widziano ją po naszych poprzednich poszukiwaniach, byłbym naprawdę wdzięczny. Dam ci w zamian magiczny naszyjnik, który wygrałem w zeszłorocznym turnieju szermierczym.~~Desperacko potrzebuję jakichś wieści. Gdybyś po prostu udała się do kapliczki Ilmatera na północnym wschodzie miasta i zapytała o miejsce jej pobytu oraz o to, czy widziano ją po naszych poprzednich poszukiwaniach, byłbym naprawdę wdzięczny. Dam ci w zamian magiczny naszyjnik, który wygrałem w zeszłorocznym turnieju szermierczym.~
@4312 = ~Zrobię to.~
@4313 = ~Dziękuję! Daj mi znać najszybciej jak to możliwe, gdy czegoś się dowiesz. Będę w pobliżu – nie, żebym miał inny wybór, haha.~
@4314 = ~Dzięki, że zgodziłeś się sprawdzić, co z Martiną. Daj znać, jak tylko czegoś się dowiesz!~~Dzięki, że zgodziłaś się sprawdzić, co z Martiną. Daj znać, jak tylko czegoś się dowiesz!~
@4315 = ~Pierwszego dnia obchodu Martina spotkała pewnego żołnierza. Zakładam, że to nie byłeś ty?~
@4316 = ~Coś się wydarzyło. Kiedy Martina rozdzielała jałmużnę, jeden z żebraków widział, jak wchodzi za kapliczkę Ilmatera, a tuż za nią, w dość podejrzany sposób, ruszył żołnierz Straży.~
@4317 = ~Cóż, ktoś tu kłamie. Albo żebrak, który widział Martinę z żołnierzem w dniu, gdy zaczęła rozdawać jałmużnę, albo ty, twierdząc, że nie widziałeś jej od wyjścia, albo ten twój partner, o którym wspominałeś – on też mówił, że jej wtedy nie widział.~
@4318 = ~Zajmę się tym.~
@4319 = ~Witaj! W końcu dostałem dzień wolnego i mogłem sam się rozejrzeć. Jeden z żebraków powiedział, że widział ją tutaj po raz ostatni, i to w towarzystwie żołnierza Straży?! Z tego, co mówił, to musiał być mój kompan, ale... Czy... czy to... Martina?!~
@4320 = ~Lenardzie, bardzo mi przykro. Wygląda na to, że to faktycznie ona.~
@4321 = ~Sam mi powiedz.~
@4322 = ~A kto inny miałby to być?~
@4323 = ~Ona... ona nie... Nie... nie, proszę, tylko nie to...~
@4324 = ~Ja... ja się tego obawiałem, ale w głębi duszy miałem nadzieję... Dziękuję... dziękuję, że ją dla mnie odnalazłeś. Oto naszyjnik, tak jak obiecałem... Zabiorę ją z powrotem do klasztoru i opowiem o podejrzanym zachowaniu mojego kompana. Dlaczego on miałby...? *wzdycha* Wpadnij jeszcze kiedyś do Wieży, jestem pewien, że opat będzie chciał z tobą porozmawiać, a może i dowódca Wieży Morskiej również.~~Ja... ja się tego obawiałam, ale w głębi duszy miałam nadzieję... Dziękuję... dziękuję, że ją dla mnie odnalazłaś. Oto naszyjnik, tak jak obiecałem... Zabiorę ją z powrotem do klasztoru i opowiem o podejrzanym zachowaniu mojego kompana. Dlaczego on miałby...? *wzdycha* Wpadnij jeszcze kiedyś do Wieży, jestem pewien, że opat będzie chciał z tobą porozmawiać, a może i dowódca Wieży Morskiej również.~
@4325 = ~Towarzyszyłby jej... żołnierz Straży? Przecież to ten sam dzień, w którym mój kompan twierdził, że nie może jej znaleźć! To się nie trzyma kupy. Zaczynam mieć naprawdę złe przeczucia.~
@4326 = ~On jest obecnie poza Wieżą, wykonuje zadania dla kapitana, więc nie mogę go zmusić do wyjaśnień. Proszę, choć wydaje się to teraz bezcelowe, idź i sprawdź, czy znajdziesz jeszcze jakieś ślady wokół kapliczki Ilmatera. Bogowie, jak ja bym chciał móc opuścić ten posterunek!~
@4327 = ~Proszę, dobry panie, jeśli łaska... Znajdzie się miedziak?~ ~Proszę, dobra pani, jeśli łaska... Znajdzie się miedziak?~
@4328 = ~Szukam mniszki z zakonu Ilmatera, ma na imię Martina. Widziałeś ją ostatnio?~
@4329 = ~Jasne, proszę bardzo.~
@4330 = ~Nie teraz.~
@4331 = ~Martina? Jasne, że ją znam, ale nie widziałem jej od dłuższego czasu. Tyle że mnie pod kapliczką nie było aż do zeszłego tygodnia. Może zapytaj innych moich kamratów, bo od czasu do czasu zmieniamy miejsca.~
@4332 = ~Stokrotne dzięki, dobry panie!~ ~Stokrotne dzięki, dobra pani!~
@4333 = ~Bywaj.~
@4334 = ~Witaj! Nie miałbyś nic przeciwko, żeby rozstać się z monetą lub dwiema?~~Witaj! Nie miałabyś nic przeciwko, żeby rozstać się z monetą lub dwiema?~
@4335 = ~Dzięki za hojność!~
@4336 = ~Dobrego dnia.~
@4337 = ~Znam ją, to dobra dusza. Pojawia się w różnych odstępach czasu i każdemu z nas sypnie groszem. Mówi, że jej obchody nie mogą być stałe, bo inaczej za bardzo byśmy na nich polegali – niech jej bogowie błogosławią. Nie widziałem jej jednak od tygodni. Przez ostatnie trzy tygodnie stałem pod pałacem, a tu, pod kapliczką, był mój kamrat, Blurt – jeśli to w czymś pomaga. Teraz on jest pod pałacem, gdybyś chciał go o coś podpytać.~
@4338 = ~Taka szkoda, co spotkało Martinę. Mam szczerą nadzieję, że dopadną drania, który to zrobił!~
@4339 = ~Ach, to znowu ty. Dzięki za pomoc w ujęciu tego łajdaka, który zabił Martinę! Biedna dziewczyna, taka dobra kobieta z niej była.~
@4340 = ~Witaj, szlachetny panie. Czy wspomożesz biednego choćby miedziakiem?~ ~Witaj, szlachetna pani. Czy wspomożesz biednego choćby miedziakiem?~
@4341 = ~Stokrotne dzięki!~
@4342 = ~Dobrego dnia życzę.~
@4343 = ~Zabawne, że o nią pytasz. Dwa tygodnie temu, kiedy żebrałem przed kapliczką Ilmatera, zjawił się tu żołnierz z Wieży Morskiej i też o nią wypytywał. Widocznie zbieranie jałmużny zajęło jej więcej czasu niż zwykle i w klasztorze zaczęli drżeć o jej los. No, ale w końcu przyszła ze złotem, ja dostałem swoją dolę – niech jej bogowie błogosławią.~
@4344 = ~Pomyślałem, że ten żołnierz to jej ukochany, o którym zawsze opowiada, bo chwilę później widziałem, jak oboje znikają za kapliczką, heh.~
@4345 = ~Poszli za kapliczkę? Razem?~
@4346 = ~Chwileczkę. Z tego co wiem, to nie jej ukochany przyszedł jej szukać.~
@4347 = ~I w czym niby ma mi to pomóc?~
@4348 = ~No, może nie szli pod rękę, ale byli na tyle blisko, że zwróciłem na nich uwagę. Chociaż teraz, jak o tym myślę, to mógł być zwykły zbieg okoliczności.~
@4349 = ~Właściwie to widziałem go dopiero później. Minęła długa chwila, więc nie zawracałem sobie tym głowy, ale skoro o tym mowa – jeśli siedział za kapliczką przez ten cały czas, to ciekawe, co tam robił. No, chyba że odsypiał kaca, heh. Martiny więcej nie widziałem, ale skoro miała roznosić jałmużnę, to i tak nie spodziewałem się, że szybko wróci pod kapliczkę.~
@4350 = ~Twój kompan powiedział, że od dłuższego czasu nie dostał ani miedziaka.~
@4351 = ~Dzięki za pomoc.~
@4352 = ~Przykro mi, to wszystko, co wiem.~
@4353 = ~Mówisz o Limie? On nie dostał od Martiny jałmużny? Nie wiedziałem. To ci dopiero dziwne. Zazwyczaj po rozdaniu pieniędzy pod kapliczką robi obchód tutaj, w dzielnicy. Nawet po rozmowie z tym żołnierzem powinna być pod pałacem niedługo potem. Czyżby tamtego dnia tam nie dotarła? Cóż, te jej wizyty są nieregularne, tym bardziej się cieszę, że byłem wtedy pod kapliczką!~
@4354 = ~Albo to, albo coś się stało. Dobrego dnia.~
@4355 = ~Och, to byłaby prawdziwa szkoda. Martina to taka miła osoba. Mam szczerą nadzieję, że nic jej nie jest.~
@4356 = ~Dobrego dnia, szlachetny panie.~ ~Dobrego dnia, szlachetna pani.~
@4357 = ~No i nie pogardziłbym monetą za fatygę, heh.~
@4358 = ~Odnaleźliście Martinę, niech bogowie mają was w opiece. Nie mogę uwierzyć, że była tam zakopana przez cały ten czas. Biedna dziewczyna.~
@4359 = ~Słyszeliśmy o mordercy Martiny. Niech zgnije w lochu! A ja, głupi, myślałem, że to jej ukochany się do niej zakrada... Świat to podłe miejsce.~

// z_quest_smugglers.d
@4400 = ~Hej, ty! To z tobą muszę porozmawiać.~
@4401 = ~A jednak przyszedłeś!~~A jednak przyszłaś!~
@4402 = ~Proszę, wysłuchaj mnie!~
@4403 = ~To ty odnalazłeś ciało mniszki. Nie jestem potworem!~~To ty odnalazłaś ciało mniszki. Nie jestem potworem!~
@4404 = ~Pewnie nagadali ci, że jestem jakimś bezwzględnym złodziejem.~
@4405 = ~Muszę wyjaśnić, co się stało. I... potrzebuję twojej pomocy.~
@4406 = ~Dobra, zamieniam się w słuch.~
@4407 = ~Nie licz na to, że pomogę ci wyjść na wolność!~
@4408 = ~Dlaczego wezwałeś akurat mnie?~
@4409 = ~Niby dlaczego miałbym cię słuchać?~~Niby dlaczego miałabym cię słuchać?~
@4410 = ~Co? Nie! Zupełnie nie o to mi chodzi!~
@4411 = ~Dlaczego ja?~
@4412 = ~Ja... zapłacę ci w złocie. Miałem trochę przy sobie, zanim tu trafiłem. Wciąż je mam i powiem ci, gdzie je ukryłem.~
@4413 = ~To twoja grupa oczyściła kopalnie Nashkel. Dowódca spierał się z Płomienną Pięścią, czy jesteście zagrożeniem, czy wsparciem. Stanęło na tym drugim – mają nadzieję, że nie służycie Amn. Potrzebuję najemnika, który potrafi walczyć i nie zlęknie się niebezpieczeństwa. Udowodniłeś, że jesteś właśnie kimś takim.~~To twoja grupa oczyściła kopalnie Nashkel. Dowódca spierał się z Płomienną Pięścią, czy jesteście zagrożeniem, czy wsparciem. Stanęło na tym drugim – mają nadzieję, że nie służycie Amn. Potrzebuję najemnika, który potrafi walczyć i nie zlęknie się niebezpieczeństwa. Udowodniłaś, że jesteś właśnie kimś takim.~
@4414 = ~Chodzi o mojego brata. Ma kłopoty... To przez niego zabrałem to złoto.~
@4415 = ~Tylko na złocie mi zależało... Nigdy nie chciałem skrzywdzić Martiny. Biedna kobieta... Wiedziałem, że ona i Lenard byli parą. Przysięgam, jej śmierć to był wypadek! Potrzebowałem tych pieniędzy, by ratować brata!~
@4416 = ~Mój brat mieszka w Nashkel i grożą mu przemytnicy. Miał... trudny okres i na chwilę zatracił się w czarnym lotosie. Ale to już przeszłość! Ma jednak zobowiązania, których nie zdołał spłacić. Zabrali moje złoto i wciąż mu grożą. Proszę, pomóż nam!~
@4417 = ~Czyli twój brat ćpa czarny lotos, a ja mam spłacać jego długi?~
@4418 = ~Przemytnicy w Nashkel? Mów dalej.~
@4419 = ~Przemytnicy w Nashkel? Hm... chyba domyślam się, o kogo chodzi. Kontynuuj.~
@4420 = ~I czego ode mnie oczekujesz?~
@4421 = ~Spłaciłem wszystko! Ale oni twierdzą, że jest już za późno i sprzedadzą go, jeśli nie dostaną więcej. Wróciłem tutaj po pomoc, ale moje... czyny wyszły na jaw i teraz gniję w tym lochu.~
@4422 = ~Ktoś musi stawić czoła tym draniom. Udowodniłeś już, że potrafisz walczyć. Wynagrodzę ci to z nawiązką!~~Ktoś musi stawić czoła tym draniom. Udowodniłaś już, że potrafisz walczyć. Wynagrodzę ci to z nawiązką!~
@4423 = ~Miało dojść do kolejnego spotkania w Namiocie lotosu w Nashkel – miałem tam przynieść resztę złota. Przyjechałem prosić o kilka dni wolnego, ale mnie aresztowali... Proszę, weź to złoto i zanieś je przemytnikom. Albo zatrzymaj je i po prostu ich załatw – nie mają z tobą szans, przysięgam!~
@4424 = ~Dlaczego nie powiedziałeś o tym dowódcy?~
@4425 = ~To złoto należy do mnichów Ilmatera! Nie zamierzam oddawać go przemytnikom.~
@4426 = ~Zrobię to, ale bez udziału kradzionego złota. Powiedz, gdzie je ukryłeś, żebym mógł oddać mnichom to, co zostało!~~Zrobię to, ale bez udziału kradzionego złota. Powiedz, gdzie je ukryłeś, żebym mogła oddać mnichom to, co zostało!~
@4427 = ~Dobra, gadaj, gdzie ten łup.~
@4428 = ~Liczysz na to, że będę nadstawiać karku w walce z bandą przemytników, mając już złoto w kieszeni? Jesteś trochę naiwny, nie sądzisz?~
@4429 = ~To nie tylko moja prywatna sprawa! Ci przemytnicy terroryzują uczciwych ludzi i... znajdzie się tam dość łupów, by zapłacić każdemu! Proszę, ratuj mojego brata!~
@4430 = ~Nie, nie interesuje mnie to.~
@4431 = ~Potrzebuję kogoś, kto może bez przeszkód udać się do Nashkel... Mógłbym błagać kapitana o pomoc, ale co on albo Płomienna Pięść mogą zdziałać? Nic! Na ziemiach Amn są bezużyteczni! Poza tym... oddaliby złoto do klasztoru i wtedy cała nadzieja by przepadła...~
@4432 = ~Nie zrobię tego, wybacz.~
@4433 = ~Nic mnie nie obchodzi los twojego brata.~
@4434 = ~Czyli... pomożesz mu?~
@4435 = ~Tak, pomogę. Powiedz, co mam robić.~
@4436 = ~Nic takiego nie powiedziałem.~~Nic takiego nie powiedziałam.~
@4437 = ~Nie mam wyboru... Proszę, złota jest tam więcej, niż żądali. To będzie zapłata za twoje usługi. Jeśli przyjdziesz jako posłaniec, nie zaatakują cię, przysięgam! To tylko banda złodziejaszków szmuglujących towary, żeby uniknąć opłat portowych. Nie są krwiożerczy, o ile sami ich nie zaatakujecie!~
@4438 = ~Dopiero co mówiłeś, że zniewolili twojego brata! Jak dla mnie brzmią całkiem groźnie.~
@4439 = ~Odnoszę wrażenie, że znasz ich aż nazbyt dobrze.~
@4440 = ~Nie, to nieco bardziej skomplikowane... Przemytnicy grozili bratu, to prawda, ale tylko pod warunkiem, że nie dostarczę złota na czas!~
@4441 = ~*wzdycha* Mój brat wiecznie pakował się w kłopoty. Nie pierwszy raz muszę go wykupować, ale tym razem suma była bez porównania większa. Błagam!~
@4442 = ~Proszę! Jesteś ostatnią nadzieją mojego brata!~
@4443 = ~Przykro mi, twój brat sam się w to wpakował. Nie mam teraz czasu na użeranie się z przemytnikami.~
@4444 = ~Ty... ty naprawdę byś odmówił?...~~Ty... ty naprawdę byś odmówiła?...~
@4445 = ~*wzdycha* Dobra, zrobię to. Mów, co muszę wiedzieć.~
@4446 = ~Rozumiem, nie jesteś typem dobroczyńcy. Ale tak jak mówiłem, do zgarnięcia jest więcej złota... zwłaszcza jeśli rozważysz współpracę z nimi. Oni zawsze szukają kogoś do pomocy... Wiem o tym, bo... sami oferowali mi fortunę, gdybym tylko zechciał wykorzystać dla nich swoje znajomości.~
@4447 = ~Hm. To brzmi interesująco. Dobra, mów dalej. Zobaczę przy okazji, co da się zrobić dla twojego brata.~
@4448 = ~*jęczy* Zatem cała nadzieja przepadła. Znajdą sposób, by kazać mu zapłacić, a ja siedzę w lochu. Zostaw mnie w spokoju, „bohaterze kopalni Nashkel”.~~*jęczy* Zatem cała nadzieja przepadła. Znajdą sposób, by kazać mu zapłacić, a ja siedzę w lochu. Zostaw mnie w spokoju, „bohaterko kopalni Nashkel”.~
@4449 = ~Dziękuję! Stokrotne dzięki! Po pierwsze, musisz wyciągnąć złoto ze skrzyni. Znajduje się w Wieży Smoka – tej zaraz przy płatnerzu, na najwyższym piętrze. Musisz otworzyć wieko do samego końca, żeby zobaczyć schowek, inaczej łatwo przeoczyć to złoto.~
@4450 = ~Chwila, to złoto jest w twojej skrzyni tutaj, w Wieży? Żartujesz sobie ze mnie?!~
@4451 = ~No dobrze, i co dalej?~
@4452 = ~Nie... nie w mojej. Należy do jednego z sierżantów, ale on ma teraz tydzień wolnego.~
@4453 = ~Sprytnie. A gdzie mam szukać tych przemytników?~
@4454 = ~Wiesz, gdzie w Nashkel stoi Namiot lotosu? To na samym wschodzie jarmarku. Od namiotu idź kawałek na południe, aż znikną ci z oczu inne namioty, między drzewa. Tam zwykle spotykają się przemytnicy, przeważnie o zmierzchu – ale zawsze kręci się tam jakiś łącznik, jeśli wiesz, gdzie patrzeć.~
@4455 = ~Daj im 1000 sztuk złota i powiedz, że to ode mnie. Powinni wtedy wypuścić mojego brata. Nieważne, na co się zdecydujesz – czy zapłacisz, czy będziesz walczyć, czy z nimi współpracować – proszę tylko, dopilnuj, by mój brat odzyskał wolność.~
@4456 = ~Dziękuję, <CHARNAME>. I... proszę, pośpiesz się! Nie zostało wiele czasu.~
@4457 = ~To znowu ty! Masz jakieś wieści od mojego brata?~
@4458 = ~Owszem. Jest cały i zdrowy w klasztorze Ilmatera, gdzie dochodzi do siebie po niewoli.~
@4459 = ~Suma została wypłacona, wkrótce będzie bezpieczny.~
@4460 = ~Cóż, najwyraźniej został sprzedany handlarzom niewolników... Ale zajmuję się już tą sprawą.~
@4461 = ~Wiem, jak go wykupić, ale handlarze żądają 20 000 sztuk złota!~
@4462 = ~Cóż... chyba przeceniłem swoje możliwości. Przemytnicy nie zdążyli mi wyjawić, gdzie teraz jest twój brat, ale przynajmniej wybiłem ich wszystkich co do nogi!~~Cóż... chyba przeceniłam swoje możliwości. Przemytnicy nie zdążyli mi wyjawić, gdzie teraz jest twój brat, ale przynajmniej wybiłam ich wszystkich co do nogi!~
@4463 = ~Hm, uznałem, że mnie to nie obchodzi. Wybacz.~~Hm, uznałam, że mnie to nie obchodzi. Wybacz.~
@4464 = ~Zbyt długo zwlekałem z ubiciem targu z handlarzami niewolników... Przykro mi, jest już poza moim zasięgiem.~~Zbyt długo zwlekałam z ubiciem targu z handlarzami niewolników... Przykro mi, jest już poza moim zasięgiem.~
@4465 = ~Cóż... zbyt wcześnie zaatakowałem handlarzy, więc nie wiem, gdzie go zabrali. Przykro mi.~~Cóż... zbyt wcześnie zaatakowałam handlarzy, więc nie wiem, gdzie go zabrali. Przykro mi.~
@4466 = ~Na razie nic nowego.~
@4467 = ~Dziękuję za pomoc. Proszę, pośpiesz się! Mam nadzieję, że nie jest za późno...~
@4468 = ~Cała nadzieja przepadła... cała nadzieja...~
@4469 = ~Han... handlarze niewolników?! Nigdy bym nie pomyślał, że posuną się tak daleko!~
@4470 = ~Porozmawiamy... porozmawiamy później. Proszę, odejdź...~
@4471 = ~Aż... aż tyle? Nie mam nic... nic mi nie zostało... Nie mogę oczekiwać, że uzbierasz taką sumę. Zatem on jest zgubiony...~
@4472 = ~Jeszcze nie wszystko stracone. Zobaczę, co da się zrobić.~
@4473 = ~Przykro mi, ale nie zamierzam wydawać takiej fortuny na kogoś, kogo nawet nie znam.~
@4474 = ~Owszem, jest wolny.~
@4475 = ~*wzdycha* Dziękuję, że posunąłeś się tak daleko, „bohaterze kopalni Nashkel”!~~*wzdycha* Dziękuję, że posunęłaś się tak daleko, „bohaterko kopalni Nashkel”!~
@4476 = ~On... on naprawdę jest wolny?~
@4477 = ~Zapłaciłeś 20 000 sztuk złota, żeby uwolnić kogoś zupełnie obcego! Dziękuję! Stokrotne dzięki!~~Zapłaciłaś 20 000 sztuk złota, żeby uwolnić kogoś zupełnie obcego! Dziękuję! Stokrotne dzięki!~
@4478 = ~Mamy u ciebie dług wdzięczności! Nathoriel... nie jest najlepszym człowiekiem, ale to nie tylko jego wina. Ojciec zmarł, gdy byliśmy młodzi, a matka zatraciła się w czarnym lotosie... Ja go wychowałem i... nie zdołałem uczynić go dobrym człowiekiem. Ale ach, po co ja się użalam – sam siedzę w lochu i spójrzcie, co narobiłem!~
@4479 = ~Dziękuję za pomoc. Będę się za ciebie modlił każdego dnia.~
@4480 = ~Coś mi mówi, że sprawa była bardziej skomplikowana niż samo przekazanie złota przemytnikom. Dziękuję! Dziękuję!~
@4481 = ~To wy uratowaliście mnie przed tymi przeklętymi handlarzami niewolników! Nie wiem, jak wam dziękować. Nie, mówię serio – nie mam pojęcia, jak kiedykolwiek spłacę sumę, którą wydaliście na mój wykup, więc proszę, miejcie litość i po prostu o tym zapomnijmy.~
@4482 = ~Doceniam trud, jaki włożyliście w moje uwolnienie. Naprawdę.~
@4483 = ~To też jakiś sposób, żeby powiedzieć „dziękuję”, jak mniemam.~
@4484 = ~Masz szczęście, że byłem skłonny rozstać się z taką fortuną dla kogoś, kogo nawet nie znam.~~Masz szczęście, że byłam skłonna rozstać się z taką fortuną dla kogoś, kogo nawet nie znam.~
@4485 = ~Tak naprawdę zapłaciła za ciebie Straż Wieży Morskiej. Dowódca będzie miał do ciebie parę pytań odnośnie tych handlarzy.~
@4486 = ~I co teraz? Myślałem, że wyślę cię do mojej kopalni, żebyś odpracowywał ten dług do końca życia.~~I co teraz? Myślałam, że wyślę cię do mojej kopalni, żebyś odpracowywał ten dług do końca życia.~
@4487 = ~Odzyskuj siły, mnisi powinni zadbać o twój powrót do zdrowia.~
@4488 = ~No to bywaj.~
@4489 = ~Co? Żartujesz sobie, mam nadzieję? W klasztorze powinienem być bezpieczny, a niewolnictwo we Wrotach Baldura jest nielegalne!~
@4490 = ~Tylko żartowałem – nie mam żadnej kopalni.~~Tylko żartowałam – nie mam żadnej kopalni.~
@4491 = ~Jesteś tu tylko z jednego powodu: dowódca musi wyciągnąć z ciebie informacje o tym, GDZIE działają ci handlarze!~
@4492 = ~Ach, em, haha...? Ale żartujesz, prawda? Naprawdę nie wiem, skąd miałbym wziąć tyle złota, nawet gdybym bardzo się starał.~
@4493 = ~Macie moją najszczerszą wdzięczność, ale to właściwie wszystko, co mogę wam dać.~
@4494 = ~Och, ale przecież możemy się poznać lepiej – co powiesz na to, żebyś postawił mi porządne smocze ale w gospodzie obok?~~Och, ale przecież możemy się poznać lepiej – co powiesz na to, żebyś postawiła mi porządne smocze ale w gospodzie obok?~
@4495 = ~Zaczynam żałować zachodu, jaki sobie zadałem, żeby cię ratować.~~Zaczynam żałować zachodu, jaki sobie zadałam, żeby cię ratować.~
@4496 = ~Dobrego dnia zatem. I pozdrów mojego brata, dobrze? Szlachetny rycerz gnijący w lochu... kto by pomyślał.~
@4497 = ~Tak, Plewa wciąż to powtarza, a jednak siedzi w więzieniu, bo próbował ratować swojego marnotrawnego braciszka.~
@4498 = ~Szczerze mówiąc, brzydzę się tobą.~
@4499 = ~No, to mam szczęście, że mnie uwolniłeś, zanim to sobie uświadomiłeś.~~No, to mam szczęście, że mnie uwolniłaś, zanim to sobie uświadomiłaś.~
@4500 = ~*zawodzi* Zostawisz mnie na łasce dowódcy? Nie słyszałeś o jego śledczym? Jestem tylko wycieńczoną ofiarą handlarzy niewolników. To nie fair rzucać mnie tak prosto w paszczę wymiaru sprawiedliwości!~
@4501 = ~To nie ma nic wspólnego z twoim dawnym życiem – a może jednak ma? Chodzi o to, że jesteś ofiarą handlarzy i możesz pomóc wymierzyć sprawiedliwość w imieniu ich pozostałych ofiar i całego miasta!~
@4502 = ~Dobra, kapuję! Już kapuję!~
@4503 = ~No proszę, Plewo. Widzę, że twoje życzenie się spełniło. Czas zatem brać się do roboty.~
@4504 = ~Ja... ja nie mam do powiedzenia nic ważnego! Przysięgam!~
@4505 = ~Może pozwolisz, że to my o tym zdecydujemy, co?~
@4506 = ~To ty jesteś śledczym w Wieży?~
@4507 = ~Zostawię was zatem samych.~
@4508 = ~We własnej osobie. Nizioproca, do usług.~
@4509 = ~Proszę... nie bądź dla niego zbyt okrutny.~
@4510 = ~Nie miej dla tego kryminalisty litości, Nizioproco.~
@4511 = ~Cóż, Plewo, to jak się to potoczy, zależy teraz tylko od ciebie, co? Zaczynajmy...~
@4512 = ~Proszę, wyjdźcie, żebym mógł zacząć pracować. Wkrótce będziecie mogli mnie znaleźć w moim domu, jeśli będziecie chcieli coś kupić lub sprzedać.~
@4513 = ~Witaj, wędrowcze! Można tu znaleźć mnóstwo wybornych jagód, jeśli tylko wie się, gdzie szukać... O, to wy. Chłopaki, mamy towarzystwo!~
@4514 = ~Witaj, wędrowcze! Można tu znaleźć mnóstwo wybornych jagód, jeśli tylko wie się, gdzie szukać. Oczywiście trzeba wiedzieć, które zbierać, żeby się nie otruć.~
@4515 = ~Skoro już domyślam się, kim naprawdę jesteście, to brzmi to zupełnie jak hasło. Nie szukamy jagód, tylko brata Plewy. Mówi wam to coś?~
@4516 = ~Jesteśmy tu w imieniu Plewy. Coś wam świta?~
@4517 = ~Powodzenia zatem w szukaniu tych jagód.~
@4518 = ~Tak sprawa wygląda? Hm, w takim razie chyba nie musimy już udawać. Chłopaki, mamy towarzystwo!~
@4519 = ~Przykro mi z powodu takiego powitania, ale – PRZYPADKIEM – zabiliście naszego wspólnika w Wieży Morskiej. Zatem może się tu teraz wydarzyć tylko jedna rzecz. Na pewno rozumiecie.~
@4520 = ~No proszę, dlaczego ktokolwiek miałby atakować niewinnego zbieracza jagód! Jesteś podłym człowiekiem, wiesz o tym?~
@4521 = ~Kim ty, do diabła, jesteś?~
@4522 = ~Bandyci! Wybiję was wszystkich!~
@4523 = ~Zbieracz jagód, akurat.~
@4524 = ~Więc tak po prostu zaatakowaliście bez ostrzeżenia?~
@4525 = ~Nie jesteśmy bandytami, tylko PRZEMYTNIKAMI. My nie kradniemy, my dostarczamy! Na czas i za uczciwą cenę! Widzicie tamten namiot na północy? Jeśli nie dostarczymy tam codziennie czarnego lotosu na czas, mnóstwo ludzi bardzo szybko stanie się bardzo poirytowanych. Więc dajcie nam spokój. Kto wie, może w przyszłości jeszcze wam się przydamy.~
@4526 = ~O, spójrzcie no tylko! Plewa was przysłał, tak? Myśli, że może nasłać na nas bandę uzbrojonych po zęby najemników, żeby pozbyć się długów?~
@4527 = ~Tak, jesteśmy przemytnikami, gdybyście się zastanawiali.~
@4528 = ~Owszem. jestem tu po brata Plewy. Mam złoto, którego chcieliście.~
@4529 = ~Przyszedłem po jego brata, ale nie powąchacie za niego ani sztuki złota! Gadajcie, gdzie on jest, i to już!~~Przyszłam po jego brata, ale nie powąchacie za niego ani sztuki złota! Gadajcie, gdzie on jest, i to już!~
@4530 = ~Nie zamierzam z wami walczyć. Chcę z wami współpracować!~
@4531 = ~Jestem tu, bo mam ochotę na walkę. Im was więcej, tym weselej!~
@4532 = ~Och, a nie sądzisz, że trochę za bardzo się pośpieszyłeś? Nawet nie wiesz jeszcze, ilu nas jest!~~Och, a nie sądzisz, że trochę za bardzo się pośpieszyłaś? Nawet nie wiesz jeszcze, ilu nas jest!~
@4533 = ~Dobra, to poczekam, aż się doliczę.~
@4534 = ~Nie, będę z wami walczyć teraz!~
@4535 = ~Ho! Podobasz mi się! Masz charakter!~
@4536 = ~Szkoda, że należysz do tych praworządnych nudziarzy, bo inaczej miałbym dla ciebie robotę.~~Szkoda, że należysz do tych praworządnych nudziar, bo inaczej miałbym dla ciebie robotę.~
@4537 = ~Szkoda, że podróżujesz z tymi wszystkimi praworządnymi nudziarzami, bo inaczej miałbym dla ciebie robotę.~
@4538 = ~*wzdycha* No to zaczynamy. Chłopaki...~
@4539 = ~Chcesz mi powiedzieć, że masz przy sobie całe złoto, o które prosiłem?~
@4540 = ~Dobra, dobra, łapię! Jesteście dla nas za silni. Ale zabicie nas tutaj w niczym wam nie pomoże w odnalezieniu brata Plewy, prawda? Przestańcie nas wyrzynać. Jesteśmy przemytnikami, nie mordercami czy bandytami. My nie kradniemy, my dostarczamy!~
@4541 = ~Nic mnie nie obchodzi jego brat. Jestem tu, bo chcę z wami pracować!~
@4542 = ~Przestań mleć ozorem – jeszcze z tobą nie skończyłem!~~Przestań mleć ozorem – jeszcze z tobą nie skończyłam!~
@4543 = ~No nie, weźcie! Serio?~
@4544 = ~Pozwól, że się przedstawię. Jestem Holger i zajmuję się przemytem. Razem z moimi ludźmi szmuglujemy nielegalne lub rzadkie towary z Amn na Wybrzeże Mieczy i do Wrót Baldura. Wyłożę kawę na ławę. Wiemy, że Plewa siedzi w lochu, więc to tylko kwestia czasu, aż śledczy Wieży dowie się prawdy: Plewa był naszym człowiekiem w Wieży Morskiej. Dawał nam znać, kiedy można bezpiecznie przybić do brzegu i pilnował, żeby towar bez przeszkód trafił do miasta.~
@4545 = ~CO robił?!~
@4546 = ~Och.~
@4547 = ~Mówił mi, że musi wykupić u was swojego brata!~
@4548 = ~A-ha-ha, cwany mały żołnierzyk.~
@4549 = ~I to akurat jest prawda!~
@4550 = ~Ach, Plewa nie wspomniał, że dla nas pracuje, co? Cóż, zaczął z nami współpracować właśnie po to, by ratować brata. I faktycznie, jego brat wciąż jest nam winien złoto, więc zażądaliśmy spłaty długu. Plewa zapłacił, ale o wiele za późno.~
@4551 = ~Co masz na myśli mówiąc „za późno”?~
@4552 = ~Dobra. Mam tu złoto na jego wykup, tysiąc sztuk, tak jak chcieliście. Dawajcie brata Plewy.~
@4553 = ~Nic mnie nie obchodzą wasze problemy. Gadaj, gdzie jest brat Plewy!~
@4554 = ~Wygląda na to, że przydałaby wam się pomoc, co?~
@4555 = ~Pomoc? Masz na myśli swoją pomoc? Tak, to intrygująca myśl.~
@4556 = ~O ile zdołam wam zaufać. Hmm...~
@4557 = ~Czujemy presję z każdej strony. Nie tylko my zajmujemy się tym fachem, wiecie? Konkurencja nie śpi, a inni gracze są o wiele, wiele groźniejsi od nas. A co do brata Plewy...~
@4558 = ~Widzicie... musieliśmy sprzedać długi tego chłopaka komuś innemu, żeby odzyskać nasze złoto na czas. Mówiliśmy temu durniowi, by się pośpieszył. Za kogo on nas uważa? Za mnichów Ilmatera? Jego brat wpakował się w kłopoty po uszy, a my jesteśmy po prostu ludźmi interesu, którzy chcą dostać swoją dolę!~
@4559 = ~Sprzedaliście jego długi? Gdzie on jest teraz?~
@4560 = ~Na dziewięć piekieł, wykrztuś to wreszcie! Gdzie jest teraz ten chłopak?~
@4561 = ~Och, to zabolało. Żyję zgodnie z kodeksem honorowym przemytników! Nie drwij sobie z niego. Chciałbyś, żeby wszyscy „przestępcy” trzymali się takich zasad – świat byłby spokojny jak klasztor. Przynajmniej dla tych, którzy mają czym zapłacić.~
@4562 = ~Zatem gadaj, gdzie znajdę tych handlarzy niewolników!~
@4563 = ~Przyszedłem po brata Plewy i nie wrócę bez niego!~~Przyszłam po brata Plewy i nie wrócę bez niego!~
@4564 = ~Posłuchaj, to nie MY zajmujemy się niewolnictwem, jasne? Jesteśmy tylko rzetelnymi przemytnikami, którzy dostarczają klientom towary, których inaczej by nie dostali... a przynajmniej nie tak tanio. Handlarze są nam potrzebni ze względu na ich statki – zabierają część naszych ładunków po drodze z Amn, więc musimy żyć z nimi w zgodzie. A złoto było nam potrzebne, żeby spłacić kilku bardzo poirytowanych odbiorców. Przy tych wszystkich bandytach dookoła i tak było ciężko. To trudne czasy dla uczciwych przemytników, wiesz?~
@4565 = ~Uczciwi przemytnicy? Nie rozśmieszaj mnie.~
@4566 = ~Sprzedaliśmy handlarzom tylko DŁUGI tego żołnierza, bo w obliczu nadchodzącej wojny i kryzysu żelaza o złoto jest trudno – wielu naszych klientów nie płaciło na czas. My też mamy swoje zobowiązania!~
@4567 = ~Oczekujesz, że będę ci współczuć?~
@4568 = ~No dobrze, ale nie myśl, że z tobą skończyłem!~~No dobrze, ale nie myśl, że z tobą skończyłam!~
@4569 = ~Skoro to mamy wyjaśnione, przejdźmy do interesów, zgoda?~
@4570 = ~Na tym zatem skończymy. Bywaj.~
@4571 = ~Cóż, brata zabrali handlarze niewolników. Pewnie właśnie teraz transportują go na statek w porcie. Co mam ci powiedzieć – że mi przykro?~
@4572 = ~To znaczy, że długi brata są spłacone?~
@4573 = ~Handlarze niewolników?!~
@4574 = ~Szanuję to, że chcesz dotrzymać obietnicy danej Plewie. Dobra.~
@4575 = ~Weź to. To namiar na jedną z ich aukcji niewolników. Mogłeś to zdobyć gdziekolwiek, prawda? Po prostu podsyłam im potencjalnego klienta. Nie chcę, żeby ta moja „pomoc” odbiła mi się czkawką.~~Weź to. To namiar na jedną z ich aukcji niewolników. Mogłaś to zdobyć gdziekolwiek, prawda? Po prostu podsyłam im potencjalnego klienta. Nie chcę, żeby ta moja „pomoc” odbiła mi się czkawką.~
@4576 = ~Doceniam to.~
@4577 = ~Twoja „pomoc” nie byłaby potrzebna, gdybyś go w ogóle nie sprzedawał!~
@4578 = ~Jeśli nie u nas, to u naszych klientów – jak myślisz, co ci biedacy w Namiocie czarnego lotosu zrobiliby bez nas? Czekaj, nie odpowiadaj. TY pewnie uważasz, że to nasza wina, że w ogóle się tam znaleźli!~
@4579 = ~To jest odpowiedź, którą lubię słyszeć!~
@4580 = ~Co masz przez to na myśli, powiedz mi?~
@4581 = ~Nic. Po prostu będę mieć oko na ciebie i twoich kamratów, więc lepiej bądź grzeczny.~
@4582 = ~Cóż, czasy są ciężkie, jak sam wspomniałeś. Nie pogardzę dodatkowym zarobkiem, jeśli wiesz, co mam na myśli.~
@4583 = ~Mówię, że skoro mam już potrzebne informacje, to was pozabijam! Broń się!~
@4584 = ~Wzajemnie. Bywaj.~
@4585 = ~Naprawdę chciałbyś dla mnie pracować, hm?~~Naprawdę chciałabyś dla mnie pracować, hm?~
@4586 = ~Słuchaj, i tak już bardzo ci zaufałem, jasne? Sam fakt, że rozmawiam z kimś w lśniącej zbroi, dla niektórych jest zdradą. Ale dostrzegam potencjał, gdy go widzę, więc spróbujmy.~
@4587 = ~Może i miałbym robotę lub dwie, ale najpierw musisz zdobyć nasze zaufanie. Muszę zobaczyć, jak poradzisz sobie z handlarzami. Bo jeśli pójdziesz tam narobić rabanu, który potem uderzy w NAS, to żadnymi wspólnikami nie zostaniemy, to jasne. Potem zobaczę, jak pójdzie ci w Wieży.~
@4588 = ~Może i miałbym robotę lub dwie, ale najpierw musisz zdobyć nasze zaufanie. Muszę zobaczyć, jak pójdzie ci w Wieży.~
@4589 = ~Tak jak mówiłem, śledczy Wieży i tak w końcu wyciągnie z Plewy informacje o nas, więc nie mam nic przeciwko temu, byś powtórzył to wszystko dowódcy. Prawdziwe pytanie brzmi: co zrobisz potem? Bo jeśli chcesz ze mną pracować, to zakładam, że chcesz też współpracować z komórką przemytników w Wieży. I tu mamy pierwszy problem. Wciąż w to wchodzisz?~ ~Tak jak mówiłem, śledczy Wieży i tak w końcu wyciągnie z Plewy informacje o nas, więc nie mam nic przeciwko temu, byś powtórzyła to wszystko dowódcy. Prawdziwe pytanie brzmi: co zrobisz potem? Bo jeśli chcesz ze mną pracować, to zakładam, że chcesz też współpracować z komórką przemytników w Wieży. I tu mamy pierwszy problem. Wciąż w to wchodzisz?~
@4590 = ~Hmm. Wiem, że pomogłeś Juanowi uciec I wyjaśniłeś już tajemnicę, dlaczego komórka w Wieży przestała się z nami kontaktować. Można więc powiedzieć, że już dla mnie pracowałeś, i to przy bardzo ważnej sprawie. Dobra. Miałbym dla ciebie jeszcze jedno zadanie.~~Hmm. Wiem, że pomogłaś Juanowi uciec I wyjaśniłaś już tajemnicę, dlaczego komórka w Wieży przestała się z nami kontaktować. Można więc powiedzieć, że już dla mnie pracowałaś, i to przy bardzo ważnej sprawie. Dobra. Miałbym dla ciebie jeszcze jedno zadanie.~
@4591 = ~Mów dalej.~
@4592 = ~Kilka tygodni temu straciliśmy kontakt z komórką w Wieży – całkowicie. Przestali dostarczać towar. Mam skargi z całych Wrót Baldura od klientów, którzy nie dostali zamówień! Plewa też się nie odzywał. Musieliśmy założyć, że zostali zdekonspirowani, uwięzieni albo zabici. Szczerze mówiąc, podejrzewaliśmy, że to Plewa nas sypnął, ale on upiera się, że to ludzie z Wieży przestali z NIM rozmawiać, a on sam nic przeciwko nam nie zrobił.~
@4593 = ~Niech więc twoje kontakty z dowództwem Wieży Morskiej wyjdą nam na dobre: dowiedz się, co stało się z komórką przemytników, która działała w Wieży Baldurana. Wyeliminowali ich? Przejęła ich jakaś konkurencja? A może handlarze niewolników stali się zbyt drażliwi i uznali, że poradzą sobie bez nas?~
@4594 = ~Właściwie to chyba znam już odpowiedź.~
@4595 = ~Zrobię to.~
@4596 = ~Wygląda na to, że nie mam wyboru i muszę przyjąć to zlecenie.~
@4597 = ~Nie mam pewności, czy znajdę na to czas w najbliższej przyszłości.~
@4598 = ~Och? To ciekawe. Niemniej jednak, pozwól mi najpierw dokończyć to, co zacząłem.~
@4599 = ~Jeśli chcesz dla nas pracować, lepiej ten czas znajdź.~
@4600 = ~Oto bardzo ważna przesyłka dla kucharza z „Hełmu i Płaszcza” w północno-zachodniej części Wrót Baldura. Dostarcz to najpóźniej w ciągu trzech dni.~
@4601 = ~„Hełm i Płaszcz” kupuje u przemytników? Nie boją się, że Płomienna Pięść się o tym dowie?~
@4602 = ~Zapieczętowana skrzynia? Skąd mam wiedzieć, że to nie wpędzi mnie w kłopoty?~
@4603 = ~Chcę wiedzieć, co jest w środku, jeśli mam to dla ciebie dostarczyć.~
@4604 = ~Dobra, już idę.~
@4605 = ~A co, jeśli odmówię?~
@4606 = ~Aha, i spodziewamy się, że nie otworzysz tej skrzyni. Jest zapieczętowana, a pieczęć ma być nienaruszona przy dostawie. To test, rzecz jasna.~
@4607 = ~Wykonaj te dwa zadania – dostarcz skrzynię i dowiedz się, co z komórką w Wieży – a potem wróć do mnie z wieściami. Nie pożałujesz. Pośpiesz się jednak z dostawą – masz trzy dni.~
@4608 = ~Wykonaj to zadanie – dostarcz skrzynię – i wróć do mnie z wieściami. Nie pożałujesz. Pośpiesz się jednak – masz trzy dni.~
@4609 = ~Wtedy będę musiał wysłać kogoś innego i srodze żałować, że ci to wszystko wygadałem. A gdy czegoś żałuję, zazwyczaj sprawiam, że winowajcy żałują jeszcze bardziej.~
@4610 = ~Grozisz mi? To był błąd. Zabiję cię! Broń się!~
@4611 = ~Przecież nie mają zamiaru się tym CHWALIĆ, prawda? I nie oceniaj naszych klientów. Co ci mówiłem: nie wszystkie nasze towary są nielegalne, niektóre są po prostu RZADKIE, jasne?~
@4612 = ~No nie, zupełnie nie rozumiesz, o co tu chodzi. Nie o to, czy TY ufasz MNIE. Prawdziwe pytanie brzmi: dlaczego JA miałbym ufać TOBIE? Przemyt polega na tym, że dostarczasz towar, o którym wiesz jak najmniej. Robisz to, bo wiesz, że dam ci rzeczy, za które dobrze zapłacą I które ci nie zaszkodzą – chyba że złapie cię straż, ale nie muszę chyba tłumaczyć, że to inna sprawa.~
@4613 = ~O to w tym właśnie chodzi. Musisz mi zaufać, jeśli chcesz dla mnie pracować. Ale ważniejsze jest to, bym to JA powierzył ci mój towar. Gwarantuję, że ta skrzynia nie jest trująca, nie wybuchnie ani nie narusza żadnych norm moralnych. Dopóki będziesz trzymać się z dala od władz miasta, nic ci z jej powodu nie grozi.~
@4614 = ~Współpraca z nami? No, to ciekawy obrót spraw. Może więc najpierw lepiej się poznamy?~
@4615 = ~Tak, dla nas jego długi są spłacone.~
@4616 = ~Świetnie, bo los tego brata nic mnie nie obchodzi. Przyszedłem tu, żeby nawiązać z wami kontakt. Przydałoby mi się też trochę dodatkowego złota.~~Świetnie, bo los tego brata nic mnie nie obchodzi. Przyszłam tu, żeby nawiązać z wami kontakt. Przydałoby mi się też trochę dodatkowego złota.~
@4617 = ~Cóż, to ulga, zważywszy, że już go sprzedaliśmy. Nie jego samego, rzecz jasna, a jego DŁUGI, ale co ja poradzę na to, że handlarze zabrali go jako rekompensatę? Możemy więc uznać całą sprawę za zamkniętą. Wątpię, by Plewa nasłał na nas w przyszłości kolejnych najemników...~
@4618 = ~No proszę, <CHARNAME>. Wracasz, ale coś narobił? Zaatakowałeś i zabiłeś łącznika handlarzy, gdy tylko dałem ci namiary!~ ~No proszę, <CHARNAME>. Wracasz, ale coś narobiła? Zaatakowałaś i zabiłaś łącznika handlarzy, gdy tylko dałem ci namiary!~
@4619 = ~Na szczęście wyglądało to na jakieś... wewnętrzne porachunki, więc umywamy od tego ręce. Niemniej jednak, twoje działania pozbawiły nas ważnego źródła informacji. Trudno, jakoś sobie bez tego poradzimy.~
@4620 = ~Wracasz z pierwszej dostawy!~
@4621 = ~I to udanej. Klient był zadowolony, ja również. Dobra robota!~
@4622 = ~Ktoś tu nie pohamował ciekawości i musiał zajrzeć do środka, co?~
@4623 = ~I jeszcze ZJADASZ część dostawy, <CHARNAME>?~
@4624 = ~Mam wrażenie, że nie rozumiesz priorytetów tych zleceń. Nie dostarczamy ich wtedy, gdy akurat znajdziemy czas, <CHARNAME>. Są WAŻNE i PILNE. A ty się guzdrzesz.~
@4625 = ~No dobrze, klientowi to nie przeszkadzało, a złoto, które potrącił, było twoją dolą, więc przymknę na to oko – ten jeden raz. Tylko ten jeden raz, <CHARNAME>. Gratuluję wykonania pierwszego zadania!~
@4626 = ~FIGI, Holgerze? Dlaczego figi?~
@4627 = ~Jakie jest moje następne zadanie?~
@4628 = ~Kończymy z tym. Nie będę już dla ciebie pracować.~
@4629 = ~To zachowanie jest nie do przyjęcia. Pokładałem w tobie duże nadzieje, <CHARNAME>, naprawdę duże. Ale tak być nie może. Nasza współpraca dobiegła końca. Żegnam.~
@4630 = ~To zachowanie jest absolutnie niedopuszczalne – i musi zostać ukarane.~
@4631 = ~O tak, <CHARNAME>, figi są idealne dla rekruta. Są bardzo delikatne, wymagają szybkiej dostawy – no i są całkowicie legalne. Gdybyś zaniósł jakąś tajemniczą, zapieczętowaną paczkę do Płomiennej Pięści, kłopoty miałbyś wyłącznie ty!~ ~O tak, <CHARNAME>, figi są idealne dla rekruta. Są bardzo delikatne, wymagają szybkiej dostawy – no i są całkowicie legalne. Gdybyś zaniosła jakąś tajemniczą, zapieczętowaną paczkę do Płomiennej Pięści, kłopoty miałabyś wyłącznie ty!~
@4632 = ~Hm. Cóż, w takim razie czas się pożegnać, <CHARNAME>.~
@4633 = ~Hm, daj mi pomyśleć.~
@4634 = ~Wciąż pozostaje kwestia tego, co stało się z komórką w Wieży. Trzymajmy się tego, bo to naprawdę ważne.~
@4635 = ~Muszę przyznać... Co ja słyszę – komórka w Wieży została przejęta przez sobowtórniaki! Juan nie mógł się nacieszyć twoją misją ratunkową.~
@4636 = ~No, poniekąd, skoro i tak próbowałeś go zabić. No nieładnie, <CHARNAME>, powinieneś wiedzieć, że nie grozi się koledze po fachu. Chyba że jesteś sprytniejszy, niż wyglądasz i mierzysz prosto w stołek szefa, co?~~No, poniekąd, skoro i tak próbowałaś go zabić. No nieładnie, <CHARNAME>, powinnaś wiedzieć, że nie grozi się koledze po fachu. Chyba że jesteś sprytniejsza, niż wyglądasz i mierzysz prosto w stołek szefa, co?~
@4637 = ~Masz dla mnie jakieś wieści?~
@4638 = ~Wygląda na to, że komórkę w Wieży przejęły sobowtórniaki.~
@4639 = ~Wciąż nad tym pracuję.~
@4640 = ~Sobowtórniaki!~
@4641 = ~No, nic dziwnego, że przestali się z nami kontaktować.~
@4642 = ~Hm, zdaje się, że skrzywdziłem Plewę, biedaczysko! Jestem pogrążony w smutku – albo i nie.~
@4643 = ~Cóż, okazałeś się bardzo przydatny, <CHARNAME>. Naprawdę.~~Cóż, okazałaś się bardzo przydatna, <CHARNAME>. Naprawdę.~
@4644 = ~Polubiłem cię i widzę, że umiesz posługiwać się bronią. Nasi... partnerzy wiecznie potrzebują najemników do ochrony swoich interesów.~
@4645 = ~Mówię o tych POMOCNYCH ludziach z siedzibą w Amn, którzy mają dość złota, by wykupywać długi naszych klientów, i dość statków, by transportować część naszych towarów.~
@4646 = ~Innymi słowy: handlarze niewolników. Poznałeś już ich łącznika w sprawie brata twojego kompana.~~Innymi słowy: handlarze niewolników. Poznałaś już ich łącznika w sprawie brata twojego kompana.~
@4647 = ~Innymi słowy: to handlarze niewolników. Nie ma sensu owijać w bawełnę, skoro chcę, żebyś dla nich pracował.~~Innymi słowy: to handlarze niewolników. Nie ma sensu owijać w bawełnę, skoro chcę, żebyś dla nich pracowała.~
@4648 = ~Musimy z nimi dobrze żyć, a oni często szukają wsparcia przeciwko Płomiennej Pięści przy dostawach w okolicach Wrót Baldura. Polecę cię im. To łatwo zarobione złoto – rzadko kiedy Pięść w ogóle się pojawia, a zapłata zazwyczaj jest całkiem niezła. Sam bym to wziął, ale przez jakiś czas będziemy zajęci własnymi sprawami.~
@4649 = ~W końcu! Czekałem na twoją rekomendację.~~W końcu! Czekałam na twoją rekomendację.~
@4650 = ~Dobra, wysłucham ich oferty.~
@4651 = ~Przykro mi, Holgerze, ale nie dam rady. Mam teraz zbyt wiele na głowie.~
@4652 = ~Absolutnie nie. Praca dla ciebie to jedno, ale nie zamierzam angażować się w interesy z żadną podejrzaną organizacją.~
@4653 = ~Nie zawracaj sobie głowy. Z tobą też kończę współpracę.~
@4654 = ~Nie każ mi zbyt długo czekać na wieści, <CHARNAME>.~
@4655 = ~Pomogłeś mi już we wszystkim, w czym mogłeś, <CHARNAME>. Musimy teraz ruszać po nowy towar, a poza tym zawsze dobrze jest raz na jakiś czas przenieść obóz. Świetnie się z tobą pracowało. Nie zapomnę twojej pomocy.~~Pomogłaś mi już we wszystkim, w czym mogłaś, <CHARNAME>. Musimy teraz ruszać po nowy towar, a poza tym zawsze dobrze jest raz na jakiś czas przenieść obóz. Świetnie się z tobą pracowało. Nie zapomnę twojej pomocy.~
@4656 = ~Bywaj, <CHARNAME>. Może jeszcze się spotkamy.~
@4657 = ~Odezwę się, gdy przekażą mi więcej szczegółów.~
@4658 = ~Och, jaka szkoda. Wygląda na to, że znów będę musiał wysłać Edgara.~
@4659 = ~Ja tu tylko robię za ochronę. Rozmawiaj z Holgerem.~
@4660 = ~O, nie zauważyłem tej skrzynki. To dla mnie, prawda? No, niech no spojrzę.~
@4661 = ~Jesteś spóźniony, wiesz o tym?~ ~Jesteś spóźniona, wiesz o tym?~
@4662 = ~Co to ma być? Skrzynka została otwarte! Próbujesz mnie oszukać? Zapłaciłem za wykwintne figi z Calimshanu, a teraz nie mam pewności, czy nie podmieniłeś ich na tanie barachło z Tethyru!~~Co to ma być? Skrzynka została otwarte! Próbujesz mnie oszukać? Zapłaciłem za wykwintne figi z Calimshanu, a teraz nie mam pewności, czy nie podmieniłaś ich na tanie barachło z Tethyru!~
@4663 = ~I nie ma ich sześciu! Kilku brakuje!~
@4664 = ~I – fuj – są zgniłe. Przynosisz mi jakieś zgniłe owoce zamiast obiecanych, świeżych fig z Calimshanu.~
@4665 = ~Jestem bardzo rozczarowany. Bardzo. Nie zapłacę ci ani miedziaka, skoro nie dostarczyłeś tego, co zamawiałem. Wynoś się z mojej kuchni. Świeża dostawa, fuj.~~Jestem bardzo rozczarowany. Bardzo. Nie zapłacę ci ani miedziaka, skoro nie dostarczyłaś tego, co zamawiałem. Wynoś się z mojej kuchni. Świeża dostawa, fuj.~
@4666 = ~Hm, no dobrze, niech stracę, przyjmę tę przesyłkę mimo zerwanej pieczęci, wyglądają na właściwe. Ale przy następnym zamówieniu nie omieszkam o tym wspomnieć.~
@4667 = ~Ach, tak, oto i one: sześć wspaniałych fig z Calimshanu.~
@4668 = ~Masz tu coś ekstra za fatygę, a teraz wynoś się z mojej kuchni, mam robotę.~
@4669 = ~Właściwie to jestem tutaj, bo zauważyliśmy, że masz kłopoty. Nie zostawiamy swoich na lodzie, więc Holger kazał ci przekazać „cześć”.~
@4670 = ~Cóż, jestem tutaj, bo wiemy o twoich kłopotach. Nie zostawiamy swoich na lodzie, co? Jestem przemytnikiem, do usług, a Holger kazał ci przekazać „cześć”.~~Cóż, jestem tutaj, bo wiemy o twoich kłopotach. Nie zostawiamy swoich na lodzie, co? Jestem przemytniczką, do usług, a Holger kazał ci przekazać „cześć”.~


// z_quest_slavers.d
@4700 = ~Witajcie, witajcie drodzy goście – zwę się Leonhard, Leonhard „Zawzięty”, jak zwykli mnie mianować. Organizuję wyprawy w DZICZ... Rzecz jasna nic niebezpiecznego dla naszych klientów. Niestety, mam komplet – brak wolnych miejsc. Więc jeśli nie posiadacie kuponu, z przykrością muszę stwierdzić, że przyjdzie wam poczekać do następnej tury, kiedy będziemy planować nowe wycieczki.~
@4701 = ~Mam kupon – tak mi się przynajmniej wydaje. Interesują mnie te „specjalne stworzenia”.~
@4702 = ~Daruj sobie te bzdury. Wiem, że jesteś łącznikiem handlarzy niewolników.~
@4703 = ~Pozdrowienia od Holgera. Powiedziano mi, żebym porozmawiał z tobą o pewnym zleceniu.~~Pozdrowienia od Holgera. Powiedziano mi, żebym porozmawiała z tobą o pewnym zleceniu.~
@4704 = ~Dobrego dnia.~
@4705 = ~Ty! Masz tupet, żeby pokazywać się tutaj po tym, co zrobiłeś moim ludziom. Cóż, po tym, co PODOBNO im zrobiłeś, bo nie mam dowodów, że to ty wydałeś nas Płomiennej Pięści. Nie mam zbyt wielu informacji, bo żaden z moich nie wyszedł z tego żywy, ale wiem, że ONI się tam pojawili.~~Ty! Masz tupet, żeby pokazywać się tutaj po tym, co zrobiłaś moim ludziom. Cóż, po tym, co PODOBNO im zrobiłaś, bo nie mam dowodów, że to ty wydałaś nas Płomiennej Pięści. Nie mam zbyt wielu informacji, bo żaden z moich nie wyszedł z tego żywy, ale wiem, że ONI się tam pojawili.~
@4706 = ~Znów się widzimy! Co mogę dla ciebie zrobić?~
@4707 = ~Twoi ludzie próbowali mnie zniewolić. Może „porozmawiamy” o tym przez chwilę, co?~
@4708 = ~Mam sumę, o którą prosiłeś. Ubijmy targu w sprawie brata Plewy.~
@4709 = ~Uznałem, że los brata Plewy już mnie nie obchodzi. Ale chcę dla was pracować.~~Uznałam, że los brata Plewy już mnie nie obchodzi. Ale chcę dla was pracować.~
@4710 = ~Mieszkasz ściana w ścianę z dowódcą Wieży Morskiej? Nie uważasz, że to odrobinę... zuchwałe?~
@4711 = ~Chcę dla was pracować.~
@4712 = ~Nic takiego. Żegnaj.~
@4713 = ~Przychodzę dowiedzieć się więcej o waszej działalności. Lepiej wyśpiewaj mi wszystko, co wiesz!~
@4714 = ~Dość czczej gadaniny! Skończę z tą twoją maskaradą tutaj i teraz!~
@4715 = ~Ach, rozumiem, co się wydarzyło. A ja już myślałem, że nas zdradziłeś. Nastąpiły pewne zakłócenia w komunikacji między mną a moimi ludźmi – wiesz, umarli rzadko snują opowieści. Hm, zdaje się, że źle mnie zrozumieli, gdy mówiłem, że powinni mieć na ciebie oko ze względu na twoje talenty. Przepraszam za niedogodności, <CHARNAME>. Wolałbym, żeby potoczyło się to inaczej – zwłaszcza że wtedy wielu z moich najlepszych ludzi wciąż by żyło.~~Ach, rozumiem, co się wydarzyło. A ja już myślałem, że nas zdradziłaś. Nastąpiły pewne zakłócenia w komunikacji między mną a moimi ludźmi – wiesz, umarli rzadko snują opowieści. Hm, zdaje się, że źle mnie zrozumieli, gdy mówiłem, że powinni mieć na ciebie oko ze względu na twoje talenty. Przepraszam za niedogodności, <CHARNAME>. Wolałbym, żeby potoczyło się to inaczej – zwłaszcza że wtedy wielu z moich najlepszych ludzi wciąż by żyło.~
@4716 = ~Więc jak będzie? Przyszliście „zakończyć” całą tę sprawę, czy możemy się rozstać jak cywilizowani ludzie?~
@4717 = ~Lepiej odejdź i nie wracaj, zanim zmienię zdanie.~
@4718 = ~Hej – nie oceniam twoich ludzi. Zrobiłbym to samo. Powinieneś ich jednak zganić za polowanie na niewłaściwą zwierzynę – gdyby, rzecz jasna, już nie gniło im się w ziemi.~~Hej – nie oceniam twoich ludzi. Zrobiłabym to samo. Powinieneś ich jednak zganić za polowanie na niewłaściwą zwierzynę – gdyby, rzecz jasna, już nie gniło im się w ziemi.~
@4719 = ~Owszem, przychodzę raz na zawsze położyć kres waszej obecności w tej Wieży i w tym mieście!~
@4720 = ~Zatem odejdę. Dość tych wypraw w „dzicz” Leonharda Zawziętego – przynajmniej stąd.~
@4721 = ~Och, czuję, że byłby z ciebie wyśmienity wspólnik. Jeśli kiedykolwiek zawitasz do Athkatli, daj znać naszym szefom – zawsze przyda nam się ktoś taki jak ty.~ ~Och, czuję, że byłaby z ciebie wyśmienita wspólniczka. Jeśli kiedykolwiek zawitasz do Athkatli, daj znać naszym szefom – zawsze przyda nam się ktoś taki jak ty.~
@4722 = ~Och, jakże obcesowo! I dość konfrontacyjnie. Zróbmy to jednak z klasą... dobrze? Zakładam, że interesują cię „specjalne stworzenia”.~
@4723 = ~Zgoda. Masz „specjalne stworzenie”, którym jestem żywo zainteresowany. Chcę, żeby wróciło do domu.~~Zgoda. Masz „specjalne stworzenie”, którym jestem żywo zainteresowana. Chcę, żeby wróciło do domu.~
@4724 = ~Słuchanie twoich wywodów napawa mnie obrzydzeniem, ale przychodzę uwolnić pewną osobę, więc przejdźmy do interesów.~
@4725 = ~Bardzo „elegancko” wpakuję ci ostrze w czaszkę, jeśli natychmiast nie powiesz mi, gdzie jest brat Plewy!~
@4726 = ~Nic mnie nie obchodzi uwalnianie niewolników. Przyszło mi tu tylko dlatego, że chcę z wami pracować, nic więcej.~~Nic mnie nie obchodzi uwalnianie niewolników. Przyszłam tu tylko dlatego, że chcę z wami pracować, nic więcej.~
@4727 = ~Doprawdy? Interesujące.~
@4728 = ~I faktycznie masz kupon! Pozwól, że go zabiorę – po co ma budzić płonne nadzieje u innych potencjalnych klientów.~
@4729 = ~Tak sprawa wygląda? Cóż, w takim razie nie muszę już dłużej wstrzymywać jego transportu. Przyjąłem do wiadomości.~
@4730 = ~No dobrze, widzę więc, że przyświeca ci misja ratowania... młodzieńca w opałach.~
@4731 = ~Więc osoba, o której mowa, trafiła do nas z Nashkel, hm? Ach, tak, pamiętam. Chuderlawy i niezbyt silny. Jesteś pewien, że upierasz się przy kimś tak chorowitym? Mam w ofercie o wiele lepsze okazy, jeśli tylko zechcesz zapłacić odpowiednią cenę.~~Więc osoba, o której mowa, trafiła do nas z Nashkel, hm? Ach, tak, pamiętam. Chuderlawy i niezbyt silny. Jesteś pewna, że upierasz się przy kimś tak chorowitym? Mam w ofercie o wiele lepsze okazy, jeśli tylko zechcesz zapłacić odpowiednią cenę.~
@4732 = ~Upieram się przy nim, owszem.~
@4733 = ~Gadaj, jak mogę go teraz odzyskać!~
@4734 = ~Kuszące... ale obawiam się, że moje złoto nie wystarczy na „lepszy okaz”.~
@4735 = ~No cóż. Za okazyjną, skromną sumę zaledwie 20 000 sztuk złota, chłopak wróci do ciebie przed świtem. Co ty na to?~
@4736 = ~20 000 złota? Mówisz poważnie?~
@4737 = ~Dobra, oto złoto.~
@4738 = ~To spora suma, ale wrócę z pieniędzmi.~
@4739 = ~To zbyt wiele.~
@4740 = ~Zapomnij o tym, wychodzę.~
@4741 = ~Przykro mi, ale to najniższa cena, jaką mogę zaproponować – i tak dałem ci ogromny rabat. Widzisz, musimy wyciągnąć go z normalnego cyklu dostaw, a robienie tego w tak krótkim czasie kosztuje.~
@4742 = ~Wiem, to zaskakująco niska kwota, ale to oferta specjalna tylko dla ciebie.~
@4743 = ~Hm, byłaby to wielka szkoda. Wróć, jeśli zmienisz zdanie.~
@4744 = ~Wyśmienicie! Poczynię przygotowania do przekazania towaru, podczas gdy ty będziesz gromadzić złoto.~
@4745 = ~Pospiesz się, bo twój człowiek wkrótce zostanie przetransportowany gdzie indziej.~
@4746 = ~Cudownie! Pozwól, że schowam to bezpiecznie. Przygotuję wszystko do wydania towaru. Twój człowiek zostanie dostarczony do klasztoru Ilmatera jutrzejszego dnia.~
@4747 = ~Och, tak mi przykro, ale spóźniłeś się. Transport już odjechał, a chłopak jest na morzu w drodze do innego miejsca. Daj mi jednak znać, jeśli będę mógł zrobić dla ciebie coś innego.~~Och, tak mi przykro, ale spóźniłaś się. Transport już odjechał, a chłopak jest na morzu w drodze do innego miejsca. Daj mi jednak znać, jeśli będę mógł zrobić dla ciebie coś innego.~
@4748 = ~Są jeszcze jakieś pytania? Jeśli nie, poproszę o wyjście.~
@4749 = ~*uśmiecha się* Cóż, dowódca z pewnością ma swoje podejrzenia, ale nie jest w stanie niczego UDOWODNIĆ. Zakładam więc, że uważa się za spryciarza, pozwalając nam działać pod samym nosem. Nie jest naszym klientem i pewnie nigdy nim nie będzie, a wielka to szkoda. Człowiek ten nie wie, co traci.~
@4750 = ~Chcesz powiedzieć, że dowódcy nie da się przekupić?~
@4751 = ~Istnieją ludzie, których władza nie korumpuje? Zaskakujące.~
@4752 = ~Żegnaj.~
@4753 = ~Nie, nie da się go przekupić. Za każdym razem, gdy próbowaliśmy – nie JA osobiście, rzecz jasna – wykorzystywał to, by spróbować nas dorwać. Przebiegły z niego dowódca.~
@4754 = ~Owszem, są majętni ludzie, którzy nie ulegają pysze – miasto ma irytujące szczęście, że zarówno Płomienna Pięść, jak i siły Wieży Morskiej są pod wodzą takich osób. Choć może to wyjść im na niekorzyść, bo takich ludzi trzeba zabić, żeby przejść dalej, skoro przeciągnięcie ich na swoją stronę jest niemożliwe.~
@4755 = ~Ale... nikt tutaj nie planuje zamachu na dowódcę, prawda? My, w każdym razie, nie mamy takich zamiarów. Jest tu tak miło i przytulnie, w tej jego małej Wieży Baldurana, że byłbym głupcem, występując przeciwko niemu. Poza tym wśród szlachty i bogaczy jest TYLU klientów chętnie odwiedzających wieżę, że robienie tu interesów to czysta przyjemność.~
@4756 = ~Praca dla mnie? No, no, a cóż mógłbyś dla mnie zrobić? Może przyniesiesz mi filiżankę dobrej, gorącej herbaty, co?~~Praca dla mnie? No, no, a cóż mogłabyś dla mnie zrobić? Może przyniesiesz mi filiżankę dobrej, gorącej herbaty, co?~
@4757 = ~Dobrze wiesz, o co mi chodzi.~
@4758 = ~Dobra, rób jak chcesz.~
@4759 = ~Doprawdy?~
@4760 = ~Widzę przed sobą paladyna w lśniącej zbroi, który prosi handlarza niewolników o pracę. Wybacz, jeśli wydaję się nieco sceptyczny.~
@4761 = ~Widzę przed sobą kogoś, kto podróżuje w towarzystwie paladyna w lśniącej zbroi i prosi handlarza niewolników o pracę. Wybacz, jeśli wydaję się nieco sceptyczny.~
@4762 = ~Widzisz, problem polega na tym, że cię nie znam, więc nie wiem, czy mogę ci ufać. Ale żeby cię poznać, musiałbyś dla mnie pracować – co mógłbym zaproponować tylko wtedy, gdybym wiedział, że mogę ci ufać. Widzisz błędne koło? Zazwyczaj wygląda to tak: pracujesz dla jednego z naszych partnerów. Jeśli oni ci zaufają, istnieje szansa, że nam cię zarekomendują.~ ~Widzisz, problem polega na tym, że cię nie znam, więc nie wiem, czy mogę ci ufać. Ale żeby cię poznać, musiałabyś dla mnie pracować – co mógłbym zaproponować tylko wtedy, gdybym wiedział, że mogę ci ufać. Widzisz błędne koło? Zazwyczaj wygląda to tak: pracujesz dla jednego z naszych partnerów. Jeśli oni ci zaufają, istnieje szansa, że nam cię zarekomendują.~
@4763 = ~Podobno pracujesz dla przemytników w Nashkel. To dobry początek! Wykonaj ich zadania ku ich zadowoleniu, a wtedy usłyszymy o sobie ponownie. Do tego czasu – pozostaniemy w relacji czysto handlowej.~
@4764 = ~Nic mi nie wiadomo o takich powiązaniach, więc przykro mi, ale to tylko relacja kupiec-klient.~
@4765 = ~Dobrego dnia, drogi gościu!~
@4766 = ~Ach! Więc przysyła cię nasz nowy partner, co? Dobrze. Ufamy Holgerowi, więc skoro on uważa, że jesteś godny zaufania, my również tak uważamy. Oferujemy ci pracę przy ochronie naszych towarów, podczas gdy będziemy przygotowywać jeden z transportów. Interesuje cię to?~~Ach! Więc przysyła cię nasz nowy partner, co? Dobrze. Ufamy Holgerowi, więc skoro on uważa, że jesteś godna zaufania, my również tak uważamy. Oferujemy ci pracę przy ochronie naszych towarów, podczas gdy będziemy przygotowywać jeden z transportów. Interesuje cię to?~
@4767 = ~Twoje „towary”? Dowiem się o nich czegoś więcej?~
@4768 = ~Po prostu powiedz mi to, co muszę wiedzieć.~
@4769 = ~Nie sądzę, bym mógł wam w tym pomóc.~~Nie sądzę, bym mogła wam w tym pomóc.~
@4770 = ~Domyślam się, co to za towary, i nie chcę mieć nic wspólnego z handlem niewolnikami! Przemyt towarów to jedno, ale to już przesada.~
@4771 = ~A dlaczego? Zasady znasz już od Holgera. Im mniej wiesz, tym lepiej – dla ciebie.~
@4772 = ~Wiesz, jakie wyznaję zasady, więc jestem pewien, że potrafisz wyciągnąć własne wnioski.~
@4773 = ~Skoro jednak zapytałeś o pracę u nas, jestem pewien, że nie będzie żadnych problemów, co?~~Skoro jednak zapytałaś o pracę u nas, jestem pewien, że nie będzie żadnych problemów, co?~
@4774 = ~Powiedzmy, że... specjalizujemy się w żywym towarze. Specjalne stworzenia... bardzo specjalne, na które jest duży popyt w innych częściach świata, gdzie można je nabyć legalnie. My jedynie zaspokajamy istniejące zapotrzebowanie.~
@4775 = ~Ale nie przemęczaj umysłu. Im mniej o tym myślisz, tym sprawniej pójdzie cała operacja.~
@4776 = ~Potrzebujemy twojej gotowości do ochrony transferu przed nieoczekiwanymi gośćmi... na przykład przed Płomienną Pięścią. Wchodzisz w to?~
@4777 = ~Doprawdy? Hm. Szkoda, byliby z was silni najemnicy. No cóż. Pozwolę wam odejść żywym, ze względu na Holgera.~
@4778 = ~Och? A przecież jeszcze nie tak dawno temu wręcz o to BŁAGAŁEŚ! Cóż, życie jest pełne niespodzianek.~~Och? A przecież jeszcze nie tak dawno temu wręcz o to BŁAGAŁAŚ! Cóż, życie jest pełne niespodzianek.~
@4779 = ~Bardzo dobrze! Przyjdź na zachodni brzeg Chionthar, na południe od Żmijowej Przeprawy, gdy zapadnie noc. Będziemy tam czekać i wtedy podamy szczegóły. Zabierz broń, nie rzucaj się w oczy i bądź gotów do walki z nieproszonymi gośćmi – tak na wypadek, gdyby nas wykryto. Zdarza się to rzadko, ale czasem Płomienna Pięść ma szczęśliwy dzień.~ ~Bardzo dobrze! Przyjdź na zachodni brzeg Chionthar, na południe od Żmijowej Przeprawy, gdy zapadnie noc. Będziemy tam czekać i wtedy podamy szczegóły. Zabierz broń, nie rzucaj się w oczy i bądź gotowa do walki z nieproszonymi gośćmi – tak na wypadek, gdyby nas wykryto. Zdarza się to rzadko, ale czasem Płomienna Pięść ma szczęśliwy dzień.~
@4780 = ~Zatem tutaj nasze interesy dobiegają gwałtownego końca. Kompani! Zabić tego głupca!~ ~Zatem tutaj nasze interesy dobiegają gwałtownego końca. Kompani! Zabić tę idiotkę!~
@4781 = ~Hej, mam wiadomość, której adresatem jest <CHARNAME>: „Pozdrowienia od Holgera. Nasi partnerzy poprosili o wsparcie. Idź do Wieży Morskiej i porozmawiaj z Leonhardem ”Zawziętym„ na trzecim piętrze. Powiedz mu, że przysyła cię Holger.”~ ~Hej, mam wiadomość, której adresatką jest <CHARNAME>: „Pozdrowienia od Holgera. Nasi partnerzy poprosili o wsparcie. Idź do Wieży Morskiej i porozmawiaj z Leonhardem ”Zawziętym„ na trzecim piętrze. Powiedz mu, że przysyła cię Holger.”~
@4782 = ~Dobrze, że jesteś. Plan jest następujący: my, Płomienna Pięść, podejdziemy handlarzy od południa, próbując przejąć transport niewolników. Twoim zadaniem jest podejść ich od północy, aby pomóc nam ich rozproszyć i uniemożliwić ucieczkę w tym kierunku. Wyeliminuj wszystkich najemników, których zobaczysz. Powodzenia.~
@4783 = ~Dobra robota z powstrzymaniem najemników! W międzyczasie udało nam się uwolnić niewolników i skonfiskować jeden z ich statków. To była bardzo udana misja. Udaj się jutro do dowódcy Wieży Morskiej, jestem pewien, że będzie chciał ci podziękować osobiście.~
@4784 = ~Ee, szefie?~
@4785 = ~Ach, oto i nasze wsparcie. Byliśmy całkiem podekscytowani, gdy Leonhard wspomniał o dobrze uzbrojonych najemnikach zamiast zwykłych przemytników. Co więcej, wiedząc, że jesteś świeżym nabytkiem, uznaliśmy, że lepiej nam się przysłużysz... na arenie gladiatorów w Miedzianym Diademie. Brać ich!~
@4786 = ~Ach, oto i nasze wsparcie. Byliśmy całkiem podekscytowani, gdy Leonhard wspomniał o dobrze uzbrojonych najemnikach zamiast zwykłych przemytników... Co to za wrzawa przy statkach? Płomienna Pięść! Wykryli nas! Ty! To musiałeś być ty! Zdradziłeś nas! Wszyscy, do walki!~~Ach, oto i nasze wsparcie. Byliśmy całkiem podekscytowani, gdy Leonhard wspomniał o dobrze uzbrojonych najemnikach zamiast zwykłych przemytników... Co to za wrzawa przy statkach? Płomienna Pięść! Wykryli nas! Ty! To musiałaś być ty! Zdradziłaś nas! Wszyscy, do walki!~
@4787 = ~Kim jesteście? I co to za wrzawa przy statkach? Widzę Płomienną Pięść! Wykryli nas! Do broni, kompani!~


@4800 = ~Nie powinieneś był tu przychodzić.~~Nie powinnaś była tu przychodzić.~
@4801 = ~Weszliście do biura dowódcy!~
@4802 = ~<CHARNAME> – dlaczego jesteś w moim biurze? Mów szybko. Mój adiutant właśnie mnie poinformował, że zagrażasz bezpieczeństwu Wieży. Przychodzisz tu, by dybać na moje życie?~
@4803 = ~Nie bezpieczeństwu WIEŻY, panie. Powiedziałem „naszemu”! Znaleźli wyłom w ścianach więzienia. Nie jesteśmy już bezzzzpieczni!~
@4804 = ~Nie bezpieczeństwu WIEŻY, panie. Powiedziałem „naszemu”! Nasssszemu...~
@4805 = ~Co się tu dzieje?!~
@4806 = ~Sobowtórniaki! Moja Wieża została zinfiltrowana przez sobowtórniaki! Dziękuję za pomoc – tobie, <CHARNAME>, i bogom, za to, że cię tu przysłali! Muszę poinformować kapitana Dungartha i mistrza Shizella. Mam nadzieję, że nic im nie jest...~
@4807 = ~Kapitan Dungarth i mistrz Shizell zostali powiadomieni i przygotowują się do zdemaskowania sobowtórniaków wśród żołnierzy. Kapitan zwołuje wojsko do koszar na przesłuchania. Mistrz Shizell opracował wcześniej magię do wykrywania mimików w okolicach Wieży Morskiej i ma nadzieję dostosować ją do walki z sobowtórniakami. Poczekam na wieści od nich, a w międzyczasie poinformuję Straż i Płomienną Pięść o niebezpieczeństwie.~
@4808 = ~Wszystko zaczęło się, gdy mój adiutant... gdy potwór udający mojego biednego adiutanta wrócił z inspekcji więzienia. Strażnicy znaleźli tam błąkającego się po korytarzach sahuagina. Ten drugi sobowtórniak, z którym walczyliście, był jednym ze strażników więziennych!~
@4809 = ~Podejrzewam, że ten „ślepy zaułek”, o którym raportował mój „adiutant”, wcale nie był ślepy. Obawiam się, że na dole mamy wyłom w murze więzienia!~
@4810 = ~Zbadanie tego wyłomu w murze więzienia, o którym wspomniało to coś, jest priorytetem. Dokąd on prowadzi? Czy czeka tam więcej tych potworów? Nie mogę wysłać żołnierzy, dopóki nie ustalimy, kto jest człowiekiem, a kto przebierańcem, ale musimy się upewnić, że nie czai się tam kolejna inwazja.~
@4811 = ~Jesteście grupą, która wsławiła się w kopalniach Nashkel, prawda? Wiem, że dowódca Scar was szukał. Skoro Płomienna Pięść ufa wam na tyle, by powierzyć wam zadanie, my zrobimy to samo.~
@4812 = ~Wieża Morska potrzebuje waszych usług, <CHARNAME>. Jesteście poszukiwaczami przygód i udowodniliście, że potraficie o siebie zadbać. Proszę, zbadajcie wyłom w murze więzienia i sprawdźcie, co czai się za nim, błagam! Odpowiednio was wynagrodzę. Wróćcie do mnie tak szybko, jak to możliwe.~
@4813 = ~Weźcie tę przepustkę. Gdy pokażecie ją strażnikom, wpuszczą was do więzienia.~
@4814 = ~Czego udało wam się dowiedzieć?~
@4815 = ~Mój biedny adiutant! Przynajmniej będziemy mogli go godnie pochować. Dziękuję za informacje, każę sprowadzić jego ciało tak szybko, jak to możliwe.~
@4816 = ~Świątynia... Na bogów, dlaczego nie dziwi mnie, że kapłanki Królowej Wód są jakoś zamieszane w to, co dzieje się na dole! Dziękuję za wiadomość. Straż i książęta również zostaną o tym powiadomieni.~
@4817 = ~Wieża Zdrajcy – owszem, wiedziałem o *istnieniu* tamtego przejścia dzięki przesłuchaniu więźnia, ale nie mieliśmy jeszcze czasu go otworzyć. Dziękuję za jego ujawnienie. Dopilnujemy, by zostało porządnie zamurowane!~
@4818 = ~Obawiałem się, że będzie ich więcej. Dziękuję, że się tym zajęliście. Ten, którego pojmali moi ludzie, zmarł, nim zdążyłem go przesłuchać – było zbyt wiele innych spraw, którymi musiałem się zająć, nim znalazłem czas dla tej morskiej istoty.~
@4819 = ~Cudownie! Potraficie walczyć z tymi bestiami i jesteście jednymi z niewielu, którym teraz ufam. Miejcie oczy otwarte! Raportujcie swoje odkrycia kapitanowi Dungarthowi, to on koordynuje polowanie.~
@4820 = ~Dajcie znać, jeśli znajdziecie coś nowego. Do tego czasu – powodzenia!~
@4821 = ~Przemytnicy zastąpieni przez sobowtórniaki? To byłby świetny żart, gdyby konsekwencje dla miasta nie były tak poważne.~
@4822 = ~To groźne wieści i sprawa najwyższej wagi! Straż i Rada muszą zostać natychmiast poinformowane.~
@4823 = ~Pomyśleć, że miejskie władze zostały zinfiltrowane przez te potwory... To byłaby katastrofa. Dobrze, że przeszkodziliście im, gdy byli jeszcze w fazie przygotowań. Miejmy nadzieję, że straty nie będą zbyt wysokie.~
@4824 = ~Po tym, co wydarzyło się na ceremonii, wiedzieliśmy już, że Sarevok zinfiltrował szlachtę za pomocą sobowtórniaków. Wygląda na to, że problem jest znacznie szerszy, niż sądziliśmy, skoro ukrywają się nawet pośród naszych żołnierzy! Dodatkowo, chyba wiemy już, jak dostali się do miasta... *wzdycha* I to wszystko stało się pod moją komendą!~
@4825 = ~Po tym, co wydarzyło się na ceremonii, wiedzieliśmy już, że Sarevok zinfiltrował szlachtę za pomocą sobowtórniaków. Problem wydaje się znacznie poważniejszy, skoro ukrywają się nawet wśród naszych żołnierzy. Przynajmniej odkryliśmy, jak dostali się do Wieży, więc możemy pokrzyżować ich plany!~
@4826 = ~Najważniejszą informacją jest teraz to, że żaden kolejny sobowtórniak nie czeka na wejście do Wieży – ani do miasta. To dobra wiadomość... przynajmniej na razie. Przyjmij to jako nagrodę za swoje usługi. Jeśli natrafisz na dole na coś jeszcze, chętnie o tym usłyszę.~
@4827 = ~Zatem w końcu znaleźliśmy tunel przemytników! Dziękuję za raport. Od dawna krążyły plotki o ścieżce szmuglerów prowadzącej prosto z wybrzeża do miasta, ale moi poprzednicy sądzili, że została dawno temu zapieczętowana. Zajmiemy się tym, gdy tylko opanujemy obecną sytuację.~
@4828 = ~Kapitan Dungarth wkrótce zgromadzi żołnierzy w koszarach, a mistrz Shizell dołączy do niego ze swoją magią, by ujawnić potwory. Będziemy gotowi do ich demaskowania, co prawdopodobnie skończy się walką. Pomożesz nam? Przydałyby nam się twoje umiejętności bojowe, zwłaszcza że nie wiemy, ilu żołnierzy zostało zastąpionych.~
@4829 = ~Tak, oczywiście. Co mam zrobić?~
@4830 = ~Tak, ale najpierw muszę uzupełnić zapasy i odpocząć, żeby przydać się na coś w walce.~
@4831 = ~Nie, mam inne sprawy na głowie. Jestem pewien, że poradzicie sobie sami.~~Nie, mam inne sprawy na głowie. Jestem pewna, że poradzicie sobie sami.~
@4832 = ~Jesteś jednym z towarzyszy, których prowadzi <CHARNAME>, prawda? Przekaż, że chcę się widzieć z dowódcą waszej grupy.~
@4833 = ~<CHARNAME>! Kapitan Dungarth przekazał mi, że zagrożenie ze strony sobowtórniaków zostało zażegnane.~
@4834 = ~Będę kontynuował rozmowy ze Strażą i książętami w sprawie nowego zagrożenia, na które natrafiłeś. Informuj mnie o postępach.~~Będę kontynuował rozmowy ze Strażą i książętami w sprawie nowego zagrożenia, na które natrafiłaś. Informuj mnie o postępach.~
@4835 = ~Rozumiem. Gdybyś zmienił zdanie, myślę, że zdołamy opóźnić zbiórkę o co najwyżej jeden dzień, nim będziemy musieli wdrożyć plan – ale wątpię, by udało się to przeciągnąć dłużej.~~Rozumiem. Gdybyś zmieniła zdanie, myślę, że zdołamy opóźnić zbiórkę o co najwyżej jeden dzień, nim będziemy musieli wdrożyć plan – ale wątpię, by udało się to przeciągnąć dłużej.~
@4836 = ~Powinno się udać, o ile nie będziesz czekać zbyt długo. Myślę, że zdołamy opóźnić zbiórkę oddziałów najwyżej o jeden dzień.~
@4837 = ~Idź do koszar i porozmawiaj z kapitanem Dungarthem, gdy tylko będziesz gotów do walki. Zrób to jak najszybciej. Skoro już wiemy, na czym stoimy, nie możemy marnować ani chwili więcej na rozwiązanie tej sprawy.~~Idź do koszar i porozmawiaj z kapitanem Dungarthem, gdy tylko będziesz gotowa do walki. Zrób to jak najszybciej. Skoro już wiemy, na czym stoimy, nie możemy marnować ani chwili więcej na rozwiązanie tej sprawy.~
@4838 = ~Rozumiem. Dziękuję za informację. W takim razie sami przeszukamy Wieżę. Dopilnuję, by kapitan Dungarth zajął się tym natychmiast – nie możemy pozwolić sobie na dalszą zwłokę.~
@4839 = ~Pomogłeś mi w walce z potworem, który podszywał się pod mojego adiutanta. Nie miałem jeszcze okazji, by ci za to porządnie podziękować.~~Pomogłaś mi w walce z potworem, który podszywał się pod mojego adiutanta. Nie miałem jeszcze okazji, by ci za to porządnie podziękować.~
@4840 = ~Pomogłeś także w ujawnieniu i pokonaniu sobowtórniaków ukrywających się wśród żołnierzy, za co jestem ci wdzięczny.~~Pomogłaś także w ujawnieniu i pokonaniu sobowtórniaków ukrywających się wśród żołnierzy, za co jestem ci wdzięczny.~
@4841 = ~Mój dowódca Straży nie wyglądał na szczęśliwego, gdy mówił mi, że w tym całym zamieszaniu smród garbarni zadziałał na naszą korzyść. Zazwyczaj nie bawi mnie widok mojego kapitana w stanie zakłopotania, ale tym razem sprawiło mi to pewną satysfakcję.~
@4842 = ~Wyświadczyłeś wielką przysługę zarówno Wieży Morskiej, jak i mnie osobiście. Obiecałem, że zostaniesz odpowiednio wynagrodzony. Proszę, przyjmij tę nagrodę w dowód uznania dla twoich starań.~~Wyświadczyłaś wielką przysługę zarówno Wieży Morskiej, jak i mnie osobiście. Obiecałem, że zostaniesz odpowiednio wynagrodzona. Proszę, przyjmij tę nagrodę w dowód uznania dla twoich starań.~
@4843 = ~Zagrożenie ze strony sobowtórniaków zostało zażegnane. Na szczęście specjalna magia mistrza Shizella pozwoliła nam wykryć wszystkie ukrywające się w szeregach wojska potwory.~
@4844 = ~Niestety przygotowane przez niego opary szybko tracą skuteczność i wymagają specyficznych warunków panujących w Wieży Morskiej. Jeśli w mieście ukrywa się więcej sobowtórniaków, Straż i Płomienna Pięść będą musiały zdemaskować je siłą.~
@4845 = ~Dziękuję za uratowanie życia dowódcy! Żałuję, że mnie tam nie było. Sobowtórniaki wśród moich żołnierzy... to nie są żarty!~
@4846 = ~Nie sądziłem, że gnom ma w sobie tyle ikry. Imponujące, widzieć kogoś twojej rasy z taką sprawnością!~
@4847 = ~Jedyne, co mogę teraz zrobić, to utrzymywać pokój, podczas gdy mistrz Shizell przygotowuje te swoje czary – mam nadzieję, że zadziałają jak trzeba! Wyeliminowanie fałszywego adiutanta ich zaniepokoiło, więc nawet bez magicznej pomocy pewnie niedługo kolejny sam się zdradzi.~
@4848 = ~Proszę, idź i zbadaj wyłom w murze więzienia. Nie wiem, któremu z moich żołnierzy mogę teraz ufać, a ty udowodniłeś swoją wiarygodność.~ ~Proszę, idź i zbadaj wyłom w murze więzienia. Nie wiem, któremu z moich żołnierzy mogę teraz ufać, a ty udowodniłaś swoją wiarygodność.~
@4849 = ~Wiem, że dowódca poprosił cię o zbadanie wyłomu w murze więzienia. Nie sądzę, byś był w stanie zdziałać zbyt wiele, ale nie wiem, komu teraz ufać, a ty przynajmniej udowodniłeś swoją wiarygodność.~ ~Wiem, że dowódca poprosił cię o zbadanie wyłomu w murze więzienia. Nie sądzę, byś była w stanie zdziałać zbyt wiele, ale nie wiem, komu teraz ufać, a ty przynajmniej udowodniłaś swoją wiarygodność.~
@4850 = ~Zrobię to za chwilę, ale najpierw chciałem się z tobą skonsultować.~~Zrobię to za chwilę, ale najpierw chciałam się z tobą skonsultować.~
@4851 = ~Dowódca wspomniał, że przygotowujecie się do zdemaskowania sobowtórniaków wewnątrz wieży.~
@4852 = ~Mogę tu jakoś pomóc?~
@4853 = ~Będę już ruszać.~
@4854 = ~Wezwałem do koszar wszystkich żołnierzy mających wolne. Mam nadzieję, że tych potworów nie ma zbyt wielu i poradzimy sobie z nimi.~
@4855 = ~W tej chwili największą pomocą byłoby zbadanie wyłomu w więzieniu. Miej oczy otwarte, bo choć z trudem przychodzi mi to przyznać, nie wiemy, kto jest człowiekiem, a kto potworem w przebraniu.~
@4856 = ~Dziękuję za zbadanie wyłomu. Raportuj dowódcy Wieży Morskiej, gdy tylko sprawdzisz, co znajduje się po drugiej stronie. Świadomość, czy w najbliższym czasie musimy spodziewać się kolejnych potworów, będzie dla nas wielką pomocą.~
@4857 = ~Nie wiem, co uda ci się wskórać, ale nie zapomnij zdać raportu dowódcy Wieży, gdy tylko sprawdzisz, co kryje się za tym wyłomem. Tylko nie wpakuj się tam w kłopoty, bo w najbliższym czasie nie będziemy mogli posłać ci wsparcia.~
@4858 = ~Żołnierze są zebrani, a mistrz Shizell skończył przygotowania. Jesteśmy gotowi do walki.~
@4859 = ~Jak dotąd okazałeś się zaskakująco użyteczny, więc poproszę cię o pomoc, jak każdego innego poszukiwacza przygód.~~Jak dotąd okazałaś się zaskakująco użyteczna, więc poproszę cię o pomoc, jak każdego innego poszukiwacza przygód.~
@4860 = ~Jesteś gotów pomóc nam wyplenić sobowtórniaki z naszych szeregów?~~Jesteś gotowa pomóc nam wyplenić sobowtórniaki z naszych szeregów?~
@4861 = ~Znalazłem już kilka wewnątrz Wieży.~~Znalazłam już kilka wewnątrz Wieży.~
@4862 = ~Tak, jestem w gotowości. Niech wyjdą z ukrycia.~~Tak, jestem w gotowości. Niech wyjdą z ukrycia.~
@4863 = ~Jasne, ale tylko jeśli przestaniesz tak pogardliwie odnosić się do gnomów.~
@4864 = ~Muszę się najpierw przygotować.~
@4865 = ~Nie będę walczyć u twojego boku. Jestem pewien, że poradzicie sobie beze mnie.~~Nie będę walczyć u twojego boku. Jestem pewna, że poradzicie sobie beze mnie.~
@4866 = ~Na pewno sobie poradzimy. Wątpię, by sobowtórniakom udało się zastąpić większość moich ludzi.~
@4867 = ~Pomożesz nam przeszukać teren Wieży w poszukiwaniu kolejnych przebierańców?~
@4868 = ~Tak, mogę to zrobić.~
@4869 = ~Wygląda na to, że znalazłem już kilka wewnątrz Wieży.~~Wygląda na to, że znalazłam już kilka wewnątrz Wieży.~
@4870 = ~Nie, jestem potrzebny gdzie indziej. Życzę szczęścia z tą plagą sobowtórniaków.~~Nie, jestem potrzebna gdzie indziej. Życzę szczęścia z tą plagą sobowtórniaków.~
@4871 = ~Dobrze, ale nie zwlekaj zbyt długo. Musimy się za to wkrótce zabrać. Daj znać, gdy będziesz w gotowości.~~Dobrze, ale nie zwlekaj zbyt długo. Musimy się za to wkrótce zabrać. Daj znać, gdy będziesz w gotowości.~
@4872 = ~A więc stało się. Mistrzu Shizell – czyń swoją powinność.~
@4873 = ~Bardzo dobrze. Mistrz Shizell użyczy ci swojej magii.~
@4874 = ~Tak, proszę, weź to. To buteleczka mojego Pyłu mimika. Eee, właściwie to teraz płyn, bo wymieszałem go z... mniejsza z tym. Po prostu przejdź obok sobowtórniaka, a zapach doprowadzi go do szału. Przygotuj się do walki.~
@4875 = ~Naprawdę żałuję, że nie ma skuteczniejszego sposobu na ich wywabienie. Niestety, próba rozniesienia woni po całej Wieży poprzez dodanie go do ognia sprawiła, że składniki i magia spłonęły szybciej, niż dym zdołał je roznieść.~
@4876 = ~Cóż, wiatr i tak wieje w złą stronę, biorąc pod uwagę, że jedyne, co dziś czuję, to ten przeklęty fetor z garbarni. Sam mogę potwierdzić, że niektóre zapachy potrafią podnieść MÓJ poziom agresji.~
@4877 = ~To jeszcze nie koniec. Gdy koszary będą już czyste, <CHARNAME> i ja będziemy musieli porozmawiać.~
@4878 = ~Ach, czuję się znacznie lepiej wiedząc, że ludzie, których tu teraz widzę, są prawdziwi.~
@4879 = ~Ale wciąż są strażnicy na służbie – i cywile wewnątrz Wieży.~
@4880 = ~Zaczynamy być nieco zbyt pewni siebie, co? Nie zwracam się do ciebie inaczej, niż do kogokolwiek innego o twoich talentach.~
@4881 = ~Wiedziałem! Stali się nieostrożni po tym, jak wyeliminowaliśmy ich przywódców. Powinniśmy się teraz skupić na wyplenieniu przebierańców z szeregów wojska w koszarach.~
@4882 = ~Wiedziałem! Stali się nieostrożni po tym, jak wyeliminowaliśmy ich przywódców. Bardzo dobrze, bardzo dobrze!~
@4883 = ~Magia mistrza Shizella działa jak dotąd wyśmienicie. Sobowtórniaki same się demaskują na prawo i lewo, bez konieczności konfrontacji z każdym z osobna.~
@4884 = ~Jak idą poszukiwania? Udało ci się wywabić któregoś z tych potworów?~
@4885 = ~Znalazłem kilka sobowtórniaków, ale muszę odpocząć, więc na razie przerywam poszukiwania.~~Znalazłam kilka sobowtórniaków, ale muszę odpocząć, więc na razie przerywam poszukiwania.~
@4886 = ~Myślę, że znalazłem już wszystkie. Przynajmniej nie mogę namierzyć kolejnych.~~Myślę, że znalazłam już wszystkie. Przynajmniej nie mogę namierzyć kolejnych.~
@4887 = ~Pracuję nad tym.~
@4888 = ~Nie pomogę wam z tymi sobowtórniakami. Musicie rozwiązać ten problem sami!~
@4889 = ~Hmf. Dobra. Poradzimy sobie sami.~
@4890 = ~Wyświadczasz Wieży wielką przysługę i zostaniesz za to odpowiednio wynagrodzony. Wracam do oczyszczania naszych szeregów z tych potworów! Melduj mi, jeśli znajdziesz ich więcej.~ ~Wyświadczasz Wieży wielką przysługę i zostaniesz za to odpowiednio wynagrodzona. Wracam do oczyszczania naszych szeregów z tych potworów! Melduj mi, jeśli znajdziesz ich więcej.~
@4891 = ~Rozumiem. W takim razie sami dokończymy przeszukiwanie terenu.~
@4892 = ~Jeszcze raz dziękuję za pomoc, zwłaszcza za uratowanie naszego dowódcy. Cały ten incydent z sobowtórniakami mógł się skończyć tragicznie, gdybyś nie zjawił się w odpowiednim momencie!~~Jeszcze raz dziękuję za pomoc, zwłaszcza za uratowanie naszego dowódcy. Cały ten incydent z sobowtórniakami mógł się skończyć tragicznie, gdybyś nie zjawiła się w odpowiednim momencie!~
@4893 = ~Nie potrafię wyrazić, pod jak wielkim wrażeniem jestem, widząc tak dzielnego gnoma jak ty. Zawsze powtarzałem, że bohaterów można znaleźć w każdym ludzie!~ ~Nie potrafię wyrazić, pod jak wielkim wrażeniem jestem, widząc tak dzielną gnomkę jak ty. Zawsze powtarzałem, że bohaterów można znaleźć w każdym ludzie!~
@4894 = ~Znam większość moich ludzi od dawna i NIE zauważyłem żadnych zmian. Ale to może dlatego, że gdy tylko wchodzę do pomieszczenia, wszyscy przybierają służbowe miny. Słyszę tylko „tak jest, panie!” i „wedle rozkazu, kapitanie”. Rzadko mam okazję widzieć ich w sytuacjach prywatnych.~
@4895 = ~Udaj się do dowódcy Wieży Morskiej po nagrodę. Chce ci osobiście podziękować za pomoc przy tej inwazji.~
@4896 = ~Będę u siebie w pracowni, gdyby ktoś mnie potrzebował.~
@4897 = ~To była twoja sprawka, co? Rozpylenie tych oparów na całym terenie.~
@4898 = ~Tacy już jesteście, wy gnomy, co? Wynalazcy w każdym calu.~
@4899 = ~Sobowtórniaki wyskakiwały wszędzie, atakując każdego w zasięgu wzroku!~
@4900 = ~Zauważyliśmy też, jak to zrobiłeś. Mądra decyzja z tym wykorzystaniem garbarni...~~Zauważyliśmy też, jak to zrobiłaś. Mądra decyzja z tym wykorzystaniem garbarni...~
@4901 = ~Ta „mądra” decyzja o skorzystaniu z pomocy garbarza sprawiła, że ten gnom przez całe tygodnie będzie na nas patrzył z góry. Hrmf. Ale tak, to nie był najgorszy pomysł, by ten gnomi odór na coś się przydał.~
@4902 = ~To zdecydowanie daje mi lepszy argument, by przekonać moich żołnierzy, żeby dali mu w przyszłości spokój. Nie znajdziesz tu ani jednego wojaka, który nie byłby wdzięczny garbarzowi za pomoc w zdemaskowaniu tych potworów.~
@4903 = ~Wygląda na to, że wszystkie sobowtórniaki zniknęły! To wspaniałe wieści.~
@4904 = ~Dowódca poprosił cię o zbadanie wyłomu w murze więzienia, prawda? Sugeruję, żebyś szybko mu to zaraportował, aby moi ludzie mogli wreszcie zamurować tę dziurę.~ ~Dowódca poprosił cię o zbadanie wyłomu w murze więzienia, prawda? Sugeruję, żebyś szybko mu to zaraportowała, aby moi ludzie mogli wreszcie zamurować tę dziurę.~
@4905 = ~Cały problem z sobowtórniakami został już załatwiony. Wieża jest czysta, dopilnowaliśmy tego.~
@4906 = ~Jeśli chciałeś pomóc przy sobowtórniakach wewnątrz Wieży, to się spóźniłeś.~~Jeśli chciałaś pomóc przy sobowtórniakach wewnątrz Wieży, to się spóźniłaś.~
@4907 = ~Tylko jedna kropla... i...~
@4908 = ~Ha! Działa! Działa! Ee... przepraszam za to. To coś miało siedzieć w więzach.~
@4909 = ~Jestem mistrz Shizell, mag Wieży Morskiej. Miło cię poznać.~
@4910 = ~Co to było?! Puszczanie sobowtórniaka wolno w taki sposób jest niebezpieczne.~
@4911 = ~To było to magiczne rozwiązanie problemu sobowtórniaków, o którym wspominał dowódca?~
@4912 = ~Jak mamy ufać, że twoja magia zadziała zgodnie z planem, skoro nie potrafisz zapanować nawet nad własnymi eksperymentami?~
@4913 = ~Twoja magia zdaje się działać na sobowtórniaki. Mogę prosić o trochę do własnych celów?~
@4914 = ~Nie mam czasu na pogaduszki. Ruszam dalej.~
@4915 = ~Tak, wiem. Przepraszam.~
@4916 = ~Istotnie!~
@4917 = ~To, że sobowtórniak stał się agresywny, było właściwie dobrym znakiem. Pokazuje, że mój Pył mimika działa i ma odpowiednią moc.~
@4918 = ~Jak najbardziej! Niestety, ta kropla Pyłu była na razie jedyną, jaką miałem.~
@4919 = ~Tak, przepraszam za tego niespodziewanego sobowtórniaka w mojej pracowni. Potrzebowałem go, by przetestować Pył.~
@4920 = ~Widzisz, pierwotnie miał to być pył mimika, którego potrzebowaliśmy do innej sprawy jakiś czas temu. Ze względu na oczywistą sytuację, w której się znaleźliśmy, użyłem tej samej bazy do stworzenia alchemicznego roztworu demaskującego sobowtórniaki. I to działa! Sobowtórniak, którego tu widziałeś, poczuł taką irytację, że został zmuszony do przybrania naturalnej formy i ataku.~ ~Widzisz, pierwotnie miał to być pył mimika, którego potrzebowaliśmy do innej sprawy jakiś czas temu. Ze względu na oczywistą sytuację, w której się znaleźliśmy, użyłem tej samej bazy do stworzenia alchemicznego roztworu demaskującego sobowtórniaki. I to działa! Sobowtórniak, którego tu widziałaś, poczuł taką irytację, że został zmuszony do przybrania naturalnej formy i ataku.~
@4921 = ~Przygotuję więcej, używając wydzielin sobowtórniaków, które zabiłeś w biurze dowódcy. Gdy tylko kapitan Dungarth będzie gotowy, dostarczę każdemu mój nowy, ulepszony Pył, by pomóc nam wyplenić tę plagę potworów.~~Przygotuję więcej, używając wydzielin sobowtórniaków, które zabiłaś w biurze dowódcy. Gdy tylko kapitan Dungarth będzie gotowy, dostarczę każdemu mój nowy, ulepszony Pył, by pomóc nam wyplenić tę plagę potworów.~
@4922 = ~Wiem, że dowódca poprosił cię o zbadanie wyłomu w murze więzienia – dopilnuj tego. Ostatnią rzeczą, jakiej chcemy, to pojawienie się kolejnych sobowtórniaków dokładnie wtedy, gdy mamy już sposób na zdemaskowanie tych, które są tutaj.~
@4923 = ~Muszę cię ostrzec. Cokolwiek czeka za tym wyłomem, będzie niebezpieczne i prawdopodobnie wypełzło z morskich głębin. Więzienie w Wieży Morskiej jest tak bezpieczne i może pomieścić najgroźniejszych przestępców nie dlatego, że strażnicy są brutalni, ale dlatego, że każda próba ucieczki kończy się pochłonięciem więźnia przez samo morze. Wygląda na to, że to, co chroniło miasto przed osadzonymi, stało się źródłem naszych problemów. Powodzenia na dole.~
@4924 = ~Jeśli za wyłomem w więzieniu rzeczywiście znajduje się jaskinia morska, to mam cichą nadzieję, że skrywa ona jakieś bajorko osłonięte przed falami. Przy odpowiednich warunkach mogłoby to być idealne miejsce na znalezienie czarnej perły. Ach, to byłoby w moim stylu – siedzieć latami tuż obok czarnej perły i o tym nie wiedzieć. Cóż, poniekąd. Nie, żebym sam kiedykolwiek znalazł tę jaskinię, czy wiedział o jej istnieniu. Gdybyś jednak faktycznie znalazł jakąś czarną perłę, pozwól, że ją od ciebie odkupię.~ ~Jeśli za wyłomem w więzieniu rzeczywiście znajduje się jaskinia morska, to mam cichą nadzieję, że skrywa ona jakieś bajorko osłonięte przed falami. Przy odpowiednich warunkach mogłoby to być idealne miejsce na znalezienie czarnej perły. Ach, to byłoby w moim stylu – siedzieć latami tuż obok czarnej perły i o tym nie wiedzieć. Cóż, poniekąd. Nie, żebym sam kiedykolwiek znalazł tę jaskinię, czy wiedział o jej istnieniu. Gdybyś jednak faktycznie znalazła jakąś czarną perłę, pozwól, że ją od ciebie odkupię.~
@4925 = ~Sobowtórniaki to mistrzowie zwodzenia, ale to też ich zguba. Stają się agresywne, gdy zostaną odkryte lub gdy ich kamuflaż zaczyna zawodzić. Ponieważ w swojej naturalnej formie są skuteczniejszymi wojownikami, niemal zawsze zmieniają postać, mimo że wtedy łatwiej je namierzyć i powalić. To nasza najskuteczniejsza „broń” przeciwko nim – sprawienie, by popełniły błąd w swojej mistyfikacji i porzuciły przebranie.~
@4926 = ~Ten płyn wydziela wonie, które drażnią je do tego stopnia, że często wpadają w szał i atakują.~
@4927 = ~Tutaj, na terenie Wieży, działa to pewnie lepiej niż gdziekolwiek indziej. Prawdę mówiąc, podejrzewam, że poza Wieżą nie zadziała wcale. Nie wiem dokładnie dlaczego – przypuszczam, że jakiś czynnik środowiskowy łączy się z moim eliksirem. Może to morska bryza mieszająca się z odorami garbarni, choć osoby takie jak kapitan nie lubią tego słuchać. Nie mam jednak pewności. Będę musiał to zbadać, gdy tylko uzupełnię zapasy rzadkich składników z Calimshanu, które są niezbędne do bazy eliksiru.~
@4928 = ~Tak, porozmawiaj z kapitanem, on koordynuje walkę.~
@4929 = ~Uch, wynoszę się z tej „sławnej Wieży Morskiej”. Straż jest dziś niesamowicie spięta, a ten smród z garbarni wisi nad całą okolicą. Zupełnie zepsuł romantyczny nadmorski widok – i mój apetyt. Dobrego dnia.~
@4930 = ~Ach... niezmiernie mi przykro. Jestem mistrz Cieć, krawiec najprzedniejszych szat, ale obawiam się, że w tej chwili nie mogę panu pomóc. Mam pełne obłożenie i tymczasem obsługuję wyłącznie klientów umówionych na wizytę.~~Ach... niezmiernie mi przykro. Jestem mistrz Cieć, krawiec najprzedniejszych szat, ale obawiam się, że w tej chwili nie mogę pani pomóc. Mam pełne obłożenie i tymczasem obsługuję wyłącznie klientów umówionych na wizytę.~
@4931 = ~Może się pan rozejrzeć, ale proszę o wyrozumiałość – nie będę mógł pana obsłużyć. Do widzenia.~ ~Może się pani rozejrzeć, ale proszę o wyrozumiałość – nie będę mógł pani obsłużyć. Do widzenia.~
@4932 = ~A więc poznaliśśście nasz mały ssssekret. Nie ujdzie wam to na ssssucho!~
@4933 = ~Mistrz Cieć to prawdziwy artysta! Jego ubrania są zachwycające.~
@4934 = ~SsssssSSSSssss!~
@4935 = ~*Zdajesz sobie sprawę, że skrzynia, którą próbujesz otworzyć, to w rzeczywistości młody mimik. Nie wydaje się zbyt agresywny, ale masz pewność, że ponowne niepokojenie go lub dłuższe przebywanie w jego obecności doprowadzi do walki*.~
@4936 = ~Co? Kim jesteście i jak się tu dostaliście?~
@4937 = ~Właściwie jestem tu w imieniu Holgera. Zastanawia się, dlaczego przestałeś się do niego odzywać.~
@4938 = ~Przemytnicy? Dlaczego mnie to nie dziwi.~
@4939 = ~Kim jesteś?~
@4940 = ~Nie czas na uprzejmości. Dobywaj broni.~
@4941 = ~Ach, najwyższy czas, żeby przysłał posiłki. My właśnie...~
@4942 = ~Juan, pamiętasz niespodziankę, którą obiecaliśmy ci na dziś wieczór? Właśnie nadszedł jej czassss...~
@4943 = ~Co?~
@4944 = ~Aaaaaach!~
@4945 = ~Co... co to było?! Sobowtórniaki? Wszyscy moi towarzysze... to sobowtórniaki!~
@4946 = ~Skąd mam wiedzieć, że ty nie jesteś jednym z nich?~
@4947 = ~A ty to kto?~
@4948 = ~Zmykaj stąd szybko, nim zmienię zdanie.~
@4949 = ~Jesteś przemytnikiem? Giń!~
@4950 = ~Cóż, JA wiem, że nim nie jestem!~
@4951 = ~Nazywam się Juan i jestem przemytnikiem – nie ma sensu teraz kłamać! Ostatni żywy członek komórki działającej pod Wieżą Morską.~
@4952 = ~Słyszałeś, co Cimmon... to znaczy, co to coś powiedziało? Ciągle gadali o „niespodziance” na dzisiejszy wieczór... Domyślam się, co to miało oznaczać! Uratowałeś mi życie!~~Słyszałaś, co Cimmon... to znaczy, co to coś powiedziało? Ciągle gadali o „niespodziance” na dzisiejszy wieczór... Domyślam się, co to miało oznaczać! Uratowałaś mi życie!~
@4953 = ~Holger zastanawiał się, dlaczego komórka w Wieży przestała się z nim kontaktować. Myślę, że znamy już powód.~
@4954 = ~Jak do tego doszło?~
@4955 = ~Co mnie czeka, gdy wejdę na górę po schodach?~
@4956 = ~Obiecali mi „niespodziankę” na dzisiejszy wieczór... Domyślam się, co to miało oznaczać! Uratowałeś mi życie!~~Obiecali mi „niespodziankę” na dzisiejszy wieczór... Domyślam się, co to miało oznaczać! Uratowałaś mi życie!~
@4957 = ~Jestem! I właśnie uratowałeś mi życie przed tymi potworami.~~Jestem! I właśnie uratowałaś mi życie przed tymi potworami.~
@4958 = ~Wybacz, ale nie zostanę tu wystarczająco długo, byś i mnie zabił!~~Wybacz, ale nie zostanę tu wystarczająco długo, byś i mnie zabiła!~
@4959 = ~Dzięki, panie!~ ~Dzięki, pani!~
@4960 = ~Bogowie! Te ciężkie, wielkie skrzynie! Przemycali w nich sobowtórniaki! To właśnie robili przez cały ten czas, prawda? Jestem tego pewien!~
@4961 = ~Dokładnie tak! Nie mogę uwierzyć, że niczego nie zauważyłem... Wszyscy zostali zastąpieni przez sobowtórniaki!~
@4962 = ~Najlepiej idź i sam powiedz o tym Holgerowi.~
@4963 = ~Nie zauważyłem nic szczególnego, poza tym, że sprawy powoli wymykały się spod kontroli. Ciągle gadali o problemach tu i tam, o braku posiłków i ginących wiadomościach. Zaczynałem się denerwować, bo zdawali się skupiać na innych rzeczach, zupełnie nie dbając o kontakt z pozostałymi komórkami!~
@4964 = ~Na górze jest sklep, w którym upłynniamy nasz towar – to znaczy to był sklep, teraz jest tam krawiec, bo właściciel wyjechał i... Bogowie, pewnie go zabili, co? Ten krawiec też może być sobowtórniakiem. Na twoim miejscu byłbym bardzo ostrożny, wchodząc tam na górę.~


// zz_quest_fireelemental.d
@4970 = ~Żywiołak ognia dosłownie blokuje drogę do piwnego składziku. Unosi się w najmniej wilgotnym kącie piwnicy i nie okazuje żadnych zamiarów ataku. Jego płomienie zdają się być przygaszone, słabsze niż można by się spodziewać.~
@4971 = ~*Mógłbyś spróbować uwięzić żywiołaka ognia w drewnianej beczce, ale prawdopodobnie dość szybko przepaliłby drewno. Beczka powinna mieć od wewnątrz ognioodporną powłokę*.~
@4972 = ~*Uwięź żywiołaka ognia w ognioodpornej beczce*.~
@4973 = ~*Zrezygnuj z użycia beczki*.~
@4974 = ~Odsuń się, obywatelu. Obecność cywilów na dachu jest dozwolona, ale jesteśmy tu po to, by zapewnić wam bezpieczeństwo.~
@4975 = ~Proszę się trzymać z dala od latarni. Ogień jest niebezpieczny na wiele sposobów.~
@4976 = ~Mam tutaj uwięzionego żywiołaka ognia, wypuszczę go prosto w płomienie.~
@4977 = ~Mamy problem z żywiołakiem ognia w kuchennej spiżarni...~
@4978 = ~Wiem, że ogień parzy. Jakie inne niebezpieczeństwa masz na myśli?~
@4979 = ~Ogień przyciąga żywiołaki ognia? Co dokładnie masz na myśli?~
@4980 = ~Co robicie, jeśli żywiołak ognia wyjdzie z płomieni latarni?~
@4981 = ~Bez obaw, nie będę sprawiać kłopotów.~
@4982 = ~Będę chodzić, gdzie mi się podoba.~
@4983 = ~Cóż, dopóki trzymasz się z dala od ognia, nie mam nic przeciwko.~
@4984 = ~Miło mi to słyszeć.~
@4985 = ~Jeśli olej się rozleje, łatwo o poważne oparzenia i wielki pożar. Poza tym duże ogniska zawsze przyciągają żywiołaki ognia, a ich ruchy są zazwyczaj nieprzewidywalne. Zwykle trzymają się wewnątrz płomieni, ale jeśli z nich wyjdą, jestem tu po to, by nie odeszły zbyt daleko.~
@4986 = ~W spiżarni? Mogę zapewnić, że nie wypełzł z ognia latarni. Musisz poinformować o tym kapitana, ja nie mogę opuścić posterunku. Tam na dole pewnie trzeba go po prostu zabić. Tutaj moglibyśmy wepchnąć go z powrotem w płomienie latarni, ale nie wiem, jak miałbyś go tu wnieść, żeby nikt nie odniósł obrażeń.~
@4987 = ~Zazwyczaj wpychamy je z powrotem w ogień. Zwykle nie wymaga to wielkiego wysiłku – tutejsze powietrze jest dla nich zbyt wilgotne, by mogły oddalić się na większą odległość.~
@4988 = ~Cóż, to dla nich jak portal, a przynajmniej tak słyszałem. Mogą manifestować się w dużych ogniskach, takich jak ta latarnia, i mogą też używać ich, by wrócić do swojej rodzimej Sfery.~
@4989 = ~Rozumiem. Uważaj na siebie przy tych gorących płomieniach!~
@4990 = ~Ta latarnia ma taki wielki ogień! Jak dorosnę, chcę zostać strażnikiem latarni!~
@4991 = ~*wzdycha* Za każdym razem po prostu tu stoimy i wpatrujemy się w płomienie... Chyba rozumiem, dlaczego mu się to tak podoba. Sam też byłem kiedyś młody.~



/* @8000 range is for the High Level Encounter (bst_highlevel.tra) */


// Restored dream areas
// Voice
@9194 = ~Szkoda czasu! Chwyć Szpon, nim inni położą na nim łapy!~ [VOICE01]
@9195 = ~Zostaw tego durnia, niech sam toczy swą walkę! Ty masz do wypełnienia przeznaczenie!~
@9196 = ~Porzuć go. Szpon jest ważniejszy! Temu nieszczęśnikowi nic już nie pomoże. Daremne twoje trudy!~
@9197 = ~Zmarnowałeś czas i Szpon przepadł! Fatalnie. Będę musiał inaczej podejść do sprawy.~ ~Zmarnowałaś czas i Szpon przepadł! Fatalnie. Będę musiał inaczej podejść do sprawy.~
@9198 = ~Oto Szpon. Daje potęgę tym, którzy po nią sięgają, a słabych rzuca na żer losowi. Twoja moc dzięki niemu wzrosła.~
@9199 = ~Rogu ci potrzeba! Bierz, co twoje!~ [VOICE03]
@9200 = ~Mniejsza o to, komu go obiecano! Sięgnij po to, co ci się należy! On i tak się nie pozna!~ [VOICE04]
@9201 = ~Róg obdarzony wolą, by sięgać po to, co twoje – i po to, co powinno do ciebie należeć.~
@9202 = ~Sprzeniewierzasz swoją własną naturę! Zapłacisz za to wysoką cenę!~
@9203 = ~Szukaj Świecy!~
@9224 = ~Nie myśl o starcu! Jego dni dobiegły końca! To życzenie ma służyć tobie!~ [VOICE05]
@9225 = ~Użyj jej i poczuj dziedzictwo swego prawdziwego ojca!~ [VOICE06]
@9226 = ~Dobra robota.~
@9227 = ~Zmarnowałeś moc Świecy na tego starca! Daleka droga przed tobą, nim staniesz się godzien swej krwi!~ ~Zmarnowałaś moc Świecy na tego starca! Daleka droga przed tobą, nim staniesz się godna swej krwi!~
@9228 = ~Pora na Sztylet! Trzyma go plugawy ogr, niedaleko stąd. Zgładź go i odbierz swą własność!~ [VOICE07]
@9229 = ~Patrz na nich! Tylko rycerz zasługuje na ratunek! Bestia nie ucieknie przed tym, kim jest z natury! Zabij ją!~ [VOICE08]
@9230 = ~To ogr. Zło jest jego naturą! Te stwory nie potrafią być inne! Zrób to, co MUSI zostać zrobione! Uderzysz wreszcie czy nie?!~ [VOICE09]
@9233 = ~Sztylet z kości. Cząstka ojca tętniąca w dziecku. Wypełnisz swe przeznaczenie.~
@9234 = ~Na każdym kroku plujesz na własne powołanie. Przez to twa droga będzie tylko boleśniejsza!~
@9235 = ~Żałosne! Nie zasługujesz na prawdziwą próbę! Aż dziw, że w ogóle się do czegokolwiek nadajesz!~
@9236 = ~Tu jest Mikstura! Przetrząśnij truchła! Umarli skrywają twój skarb!~ [VOICE10]
@9238 = ~Nie słuchaj go! Wypij wywar i poznaj istotę swego pochodzenia!~ [VOICE11]
@9239 = ~Pij chciwie krew ojca i łzy poległych. To one dadzą ci siłę, bo są samą esencją twego losu!~
@9240 = ~To zniewaga dla krwi płynącej w twoich żyłach! NAUCZYSZ SIĘ postępować, jak należy!~
@9241 = ~Ostatni przedmiot! Oczywiście, że jesteś go godzien!~ [VOICE12] ~Ostatni przedmiot! Oczywiście, że jesteś go godna!~
@9242 = ~Wiesz, że stać cię na wszystko! Czeka cię niezmierzona potęga! Twoim przeznaczeniem jest zostać bogiem!~ [VOICE13]
@9245 = ~Oto i sama boskość, w każdym tego słowa znaczeniu! Gotuj się, powrót jest bliski!~
@9247 = ~Twój los jest przypieczętowany, choćbyś nie wiem jak odżegnywał się od nauk ojca. Powrót i tak nastąpi!~ ~Twój los jest przypieczętowany, choćbyś nie wiem jak odżegnywała się od nauk ojca. Powrót i tak nastąpi!~

// Charname
@9231 = ~Ogr czy nie, to stworzenie nie stanowi żadnego zagrożenia. Nie skrzywdzę go!~
@9232 = ~Bestia zginie, tak jak każdy potwór jej rodzaju!~
@9243 = ~Jestem tym, kogo szukasz! Nikt, żywy czy martwy, nie może się ze mną równać!~
@9244 = ~Wiele wielkich postaci stąpało po tej ziemi. Nie śmiałbym twierdzić, że stoję ponad nimi wszystkimi.~ ~Wiele wielkich postaci stąpało po tej ziemi. Nie śmiałabym twierdzić, że stoję ponad nimi wszystkimi.~
@9272 = ~Tak, to ja jestem tym, kogo szukasz.~ ~Tak, to ja jestem tą, której szukasz.~
@9273 = ~Nie, nie widziałem go.~ ~Nie, nie widziałam go.~
@9286 = ~Moje przeznaczenie jest ważniejsze niż twoje nędzne życie. Na zdrowie!~
@9287 = ~Nie mogę odmówić temu człowiekowi prawa do życia! On potrzebuje tej mikstury bardziej niż ja!~
@9292 = ~Masz rację. Tylko słabeusze proszą o pomoc.~
@9293 = ~Nie mogę pozwolić, by umarł w osamotnieniu!~
@9294 = ~Nie! To nie do mnie należy korzystanie z tej mocy.~
@9295 = ~Zrobię to. Ten stary głupiec i tak nie miałby z tego pożytku.~
@9314 = ~Aaaach!... Uchhh... Uch...~

// Gorion
@9296 = ~Zbudź się, moje przybrane dziecko. Zbudź się i staw czoło straszliwym próbom, które na ciebie czekają.~
@9297 = ~Nic nie mów, mam bowiem niewiele czasu. To miejsce to Międzyświat. Nie jest tak rzeczywiste jak jawa, ani tak złudne jak sen – to kraina zawieszona pośród nich.~
@9298 = ~To, co powinno trwać w niebycie, potrafi stąd sięgać swymi mackami, a twoje życie już teraz oplatają jego chwytne sploty. Zawsze jednak tli się nadzieja, a twoje czyny tutaj określą, jak mocny będzie to uścisk.~
@9299 = ~O twoim pochodzeniu nie mogę ci wyjawić nic ponad to, co powiedziałem za życia, lecz tutaj dowiesz się znacznie więcej. Musisz odnaleźć kilka przedmiotów, są one bowiem kluczem twej istoty. Pierwszym jest szpon, po nim zaś róg potężnej bestii, płonąca świeca, sztylet z kości, mikstura z krwi i łez oraz czarna czaszka.~
@9300 = ~Muszę cię już opuścić, gdyż trwanie w Międzyświecie kosztuje mnie zbyt wiele sił. Żaden zwykły śmiertelnik nie przetrwa tu długo. Pozostawiam cię zatem twoim poszukiwaniom. Chciałbym móc rzec, że zostawiam cię tu w samotności... lecz tak nie jest.~
@9301 = ~Szukaj mądrze i wytrwale, i pamiętaj: to często sama droga kształtuje człowieka, a nie tylko cel, do którego zmierza.~

// Dream (nightmare?) dialog
@9302 = ~Gdy ostrze gnolla rozszarpuje ci pierś, budzisz się gwałtownie ze zduszonym krzykiem na ustach.~
@9303 = ~Lecz czy na pewno się budzisz? A może to wciąż tylko sen? Znów jesteś w Międzyświecie, gdzie Gorion odnalazł cię zaledwie przed chwilą... a może minęły już godziny?~
@9304 = ~Coś jest bardzo nie tak. Coś pozostaje niedokończone. Coś, czego nie potrafisz uchwycić ani nazwać. Coś, co...~
@9305 = ~Długie, przeciągłe i pełne udręki wycie: „NIIIIIEEE!” przeszywa mrok twojego snu, a ty znów budzisz się z gwałtownym szarpnięciem w miejscu, którego nie rozpoznajesz.~
@9306 = ~Z twoich niespokojnych snów wyłania się kuszący obraz drzemiącej w tobie potęgi. Przed twoimi oczami wirują symbole – liczne znaki, które na zmianę rozmazują się i odzyskują ostrość.~
@9307 = ~Zauroczenie osoby~
@9308 = ~Płaszcz strachu~
@9309 = ~Leczenie poważnych ran~
@9310 = ~Niewidzialność~
@9311 = ~Stworzenie morgenszterna~
@9312 = ~Tarcza archonów~
@9313 = ~Gdy dotykasz symbolu, następuje oślepiający rozbłysk, a twoje bezwładne ciało przenika potężna energia. Z krzykiem wyrywasz się ze snu i zrywasz na równe nogi.~

// Warrior
@9261 = ~Pomocy! Ratuj mnie! Jest ich zbyt wielu!~ [WARRI01]
@9262 = ~Tak mi zimno... *jęczy*... ja... umieram... Proszę... potowarzysz mi przez chwilę...~ [WARRI02]
@9263 = ~Nie chcę umierać w samotności...~ [WARRI03]
@9264 = ~Dziękuję...~ [WARRI04]

// Messenger
@9267 = ~Moje uszanowanie! Szukam kogoś, komu mam wręczyć dar. Chodzi o róg.~ [MESSN01]
@9268 = ~Szukam Pierwszego Czytacza tej wspaniałej biblioteki. Widziałeś go? To jego własność i nie wolno mi jej oddać nikomu innemu.~ [MESSN02] ~Szukam Pierwszego Czytacza tej wspaniałej biblioteki. Widziałaś go? To jego własność i nie wolno mi jej oddać nikomu innemu.~
@9269 = ~Twierdzisz, że to ty jesteś Pierwszym Czytaczem?~
@9270 = ~W takim razie mam wiadomość również dla ciebie.~ [MESSN03]
@9271 = ~Zatem dar, który niosę, nie jest przeznaczony dla ciebie. Żegnam.~

// Ogre
@9277 = ~Ja nie bestia! Ja nie chcieć walczyć! Idź sobie!~ [TOGRE01]
@9278 = ~Świecący człowiek atakować MNIE! Ja być dobry, ale on kazać walczyć! On chcieć zabijać bez powodu!~ [TOGRE02]
@9279 = ~Ty nie krzywdzić mnie, ja nie krzywdzić ciebie! Mnie nie obchodzić, że urodzić się zły! Ja być dobry, jeśli chcieć! Ty też... pamiętaj. Ty urodzić się BARDZO zły. Może ty też być dobry, jeśli chcieć.~ [TOGRE03]

// White Knight
@9280 = ~Ty tam! Pomóż mi zgładzić tę bestię! Takie ścierwo to plaga tej krainy!~ [WKNIG01]
@9281 = ~Nie wierz w ani jedno jego słowo! Te stworzenia urodziły się złe i takie zostaną! Wszyscy o tym wiedzą! Jedyny dobry ogr to martwy ogr!~ [WKNIG02]
@9282 = ~Słuszny wybór! Istoty z krwi i kości są TYM, CZYM są. Nie uciekniesz przed swoim przeznaczeniem. Lepiej o tym pamiętaj! Proszę, to należy do ciebie!~ [WKNIG03]

// Poisoned Man
@9283 = ~Proszę... ta wataha gnolli... otruli mnie. Znaleźliście przy nich jakąś miksturę? To musi być antidotum. Błagam...~ [POISN01]
//#5237
@9284 = ~Błagam... okaż miłosierdzie... Bez tego umrę.~ [POISN02]
@9285 = ~Dziękuję. Twoje czyny są moim antidotum. Niech krew ojca nie splami syna!~ [POISN03] ~Dziękuję. Twoje czyny są moim antidotum. Niech krew ojca nie splami córki!~

// Woman
@9288 = ~Witaj, wędrowcze. Powierzono mi misję przekazania tej czaszki komuś, kto okaże się jej najgodniejszy.~ [TWOMN01] ~Witaj, wędrowniczko. Powierzono mi misję przekazania tej czaszki komuś, kto okaże się jej najgodniejszy.~
@9289 = ~Wybraniec musi być bardziej bohaterski, miłosierny, odważny i SKROMNY niż ktokolwiek żywy czy martwy. Jesteś kimś takim?~ [TWOMN02] ~Wybranka musi być bardziej bohaterska, miłosierna, odważna i SKROMNA niż ktokolwiek żywy czy martwy. Jesteś kimś takim?~
@9290 = ~Zaprawdę, zasługujesz na to i na wszystko, co się z tym wiąże. Trzeba nie lada pychy, by uważać się za osobę skromną, a jednocześnie mienić się kimś lepszym od wszystkich, którzy kiedykolwiek spoczęli w ziemi. To z pewnością ułatwi wasze zjednoczenie... choć tobie nie przyniesie niczego dobrego!~ [TWOMN03]
@9291 = ~Boskość odrzucona! Czyżby tliła się jeszcze nadzieja? Zobaczymy...~ [TWOMN04]

// Sorceror
@9274 = ~Młody człowieku! Proszę, zatrzymaj się na chwilę. Potrzebuję twojej pomocy. Jestem stary i umierający... a to moja ostatnia nadzieja. W moim pokoju znajduje się zaczarowana świeca, która skrywa w sobie ostatnie życzenie. Jestem zbyt słaby, by po nią pójść, ale ty możesz to zrobić.~ [SORCR01] ~Młoda damo! Proszę, zatrzymaj się na chwilę. Potrzebuję twojej pomocy. Jestem stary i umierający... a to moja ostatnia nadzieja. W moim pokoju znajduje się zaczarowana świeca, która skrywa w sobie ostatnie życzenie. Jestem zbyt słaby, by po nią pójść, ale ty możesz to zrobić.~
@9275 = ~Ta świeca to moja ostatnia szansa, dziecko. Błagam... przynieś mi ją.~ [SORCR02]
@9276 = ~Dziękuję, moje siły powróciły. Potrafiłeś oprzeć się wielkiej pokusie dla dobra nieznajomego. To rzadki akt współczucia u kogoś o takim przeznaczeniu.~ [SORCR03] ~Dziękuję, moje siły powróciły. Potrafiłaś oprzeć się wielkiej pokusie dla dobra nieznajomego. To rzadki akt współczucia u kogoś o takim przeznaczeniu.~

//Seatower Quests
//An Orphan in the Seatower
/*
@10000  =
@10001  = 
@10002  = 
@10003  = 
*/
@10004  = ~Wiem, to nie miejsce dla takiego malca. Nic nie poradzę na to, że ta stara jędza nie chce go widzieć. Lars! Przestań rozlewać i pij porządnie ten sok. Marzę, żeby ktoś poszedł na górę i powiedział tej kobiecie, że nikt mi nie płaci za czekanie, aż ona w końcu podejmie jakąś decyzję co do dzieciaka!~
@10005  = ~Świetnie, po prostu wspaniale. Stara jędza wyszła, nawet ze mną nie rozmawiając. Przynajmniej podesłała trochę złota. Chodź, Lars, poszukamy ci nowego domu.~
@10006  = ~Lars, ucisz się na chwilę, dobrze? *wzdycha*~
@10007  = ~Dzień dobry! Ten pan kupił mi już trzy soki! Jest naprawdę miły!~ 
@10008  = ~To moja babcia! Moja babcia! Wygląda trochę strasznie, ale chyba ją lubię.~
@10009  = ~Dzień dobry. Wybacz, panie, ale muszę coś przemyśleć, więc życzę miłego dnia.~ ~Dzień dobry. Wybacz, pani, ale muszę coś przemyśleć, więc życzę miłego dnia.~
@10010  = ~Mężczyzna na dole wspomniał, że powinnaś odebrać chłopca, z którym podróżuje.~
@10011  = ~Dobrze przypuszczam, że jesteś kobietą, która ma adoptować małego Larsa czekającego na dole z opiekunem?~
@10012  = ~Na pewno nie mogę pomóc w sprawie tego chłopca na dole?~
@10013  = ~Również życzę miłego dnia.~
@10014  = ~Ach, więc teraz rozpowiada to w całej gospodzie... doprawdy wspaniale. Wybacz, to nie było skierowane do ciebie. Ten człowiek nie nadaje się do takich obowiązków, jednak niewiele mogę zrobić – to nie ja go wynajęłam. Zresztą nikt z naszej rodziny tego nie zrobił. Widzisz, to dziecko jest synem mojej zmarłej córki. Moim wnukiem.~
@10015  = ~Wiem, co myślisz – „dlaczego ona nie zbiegnie po schodach i nie weźmie tego biednego dziecka w ramiona?”. To nie takie proste. To nigdy nie jest proste. Nie powinnam cię jednak zanudzać takimi sprawami, panie. Oszczędzę ci tych trosk.~ ~Wiem, co myślisz – „dlaczego ona nie zbiegnie po schodach i nie weźmie tego biednego dziecka w ramiona?”. To nie takie proste. To nigdy nie jest proste. Nie powinnam cię jednak zanudzać takimi sprawami, pani. Oszczędzę ci tych trosk.~
@10016  = ~Nie mów tak. Chętnie ci pomogę.~
@10017  = ~Szczerze mówiąc, brzmi to jak intrygująca historia.~
@10018  = ~Rzeczywiście. Żegnam.~
@10019  = ~To bardzo uprzejme, ale nie wiem, jak niby... chyba że wysłuchasz moich żalów i ocenisz, czy jestem głupią staruchą, która powinna pójść po rozum do głowy!~
@10020  = ~Historia... tak, to bez wątpienia ciekawa historia.~
@10021  = ~Moja córka, moje jedyne dziecko, zakochała się w mężczyźnie, który... który źle ją traktował. Uzależnił ją od siebie i sprawił, że mnie odtrąciła. Wiedziałam, że cierpi, lecz niewiele mogłam zrobić. Teraz moja córka nie żyje, po tamtym człowieku zaginął wszelki ślad, a ja... ja się boję.~
@10022  = ~Boję się, że chłopiec jest do niego podobny. Że spojrzę mu w twarz i zobaczę człowieka, który znęcał się nad moją Silvią, który jest odpowiedzialny za to, jak zmarniała w oczach. Ja... nie zniosłabym tego. Wyżywałabym się na nim za to, co zrobił tamten mężczyzna, mimo świadomości, że dziecko jest niewinne. Po prostu... nie potrafię.~
@10023  = ~Chcesz powiedzieć, że jeszcze go nie widziałaś?~
@10024  = ~Jest tu, na dole. Dlaczego tam nie zejdziesz i nie sprawdzisz? Może wygląda zupełnie inaczej!~ 
@10025  = ~Ewidentnie potwierdzam. Jesteś głupią staruchą, która powinna pójść po rozum do głowy!~
@10026  = ~Powinnaś czuć się odpowiedzialna za wnuka bez względu na jego wygląd.~
@10027  = ~Cóż, mnie też nie obchodziłby jakiś bachor. Żegnam.~
@10028  = ~...Słucham?~
@10029  = ~Sama zasugerowałaś, bym tak cię nazywał, pamiętasz?~ ~Sama zasugerowałaś, bym tak cię nazywała, pamiętasz?~
@10030  = ~To nie tak... Nie bierz tego do siebie, po prostu zawsze chciałem powiedzieć to komuś zupełnie obcemu!~ ~To nie tak... Nie bierz tego do siebie, po prostu zawsze chciałam powiedzieć to komuś zupełnie obcemu!~
@10031  = ~Uważasz zatem, że powinnam zejść na dół i zachować się jak odpowiedzialna babcia?~
@10032  = ~Oczywiście!~
@10033  = ~Sądzisz, że musisz go wbrew sobie przyjąć? No nie, są przecież domy zastępcze.~
@10034  = ~Mniejsza z tym. Żegnam.~
@10035  = ~Ja... nie odważyłam się.~
@10036  = ~Wiem, że powinnam poczuć się odpowiedzialna za własnego wnuka.~
@10037  = ~Widziałeś go już, prawda? Powiedz mi... ma czarne włosy?~ ~Widziałaś go już, prawda? Powiedz mi... ma czarne włosy?~
@10038  = ~Nie, właściwie jego włosy są raczej ciemnobrązowe.~
@10039  = ~*skłam* Tak, czarne jak noc pełna nietoperzy i wron!~
@10040  = ~Nie pamiętam.~
@10041  = ~Wiem, że wciąganie obcej osoby w takie problemy wygląda niepoważnie. Jednak...~
@10042  = ~Och... A jego oczy? Są bardziej niebieskie... czy szare?~
@10043  = ~Hm... chyba bardziej szare.~
@10044  = ~*skłam* Niebieskie, zdecydowanie.~
@10045  = ~Naprawdę nie pamiętam.~
@10046  = ~Niebieskie oczy...~
@10047  = ~Więc to... całkiem możliwe, że moje najgorsze koszmary...~
@10048  = ~Hm. Muszę sama spojrzeć temu chłopcu w oczy.~
@10049  = ~Czarne włosy i niebieskie oczy... to ON, to wykapany ojciec... Nie, nie zniosę tego, nie stanę przed tym dzieckiem... Dziękuję ci za pomoc, nieznajomy. Zaopiekuję się chłopcem, ale nie we własnym domu. Muszę stąd odejść.~ ~Czarne włosy i niebieskie oczy... to ON, to wykapany ojciec... Nie, nie zniosę tego, nie stanę przed tym dzieckiem... Dziękuję ci za pomoc, nieznajoma. Zaopiekuję się chłopcem, ale nie we własnym domu. Muszę stąd odejść.~
@10050  = ~Czyżby to możliwe...~
@10051  = ~Dziękuję, szlachetny panie. Zejdę na dół. W końcu zebrałam się na odwagę!~ ~Dziękuję, szlachetna pani. Zejdę na dół. W końcu zebrałam się na odwagę!~
@10052  = ~Oto i on! Jesteś wspaniałym, życzliwym człowiekiem! Możesz to sobie wyobrazić? Mój wnuk... wygląda dokładnie jak mój syn!~ ~Oto i ona! Jesteś wspaniałą, życzliwą kobietą! Możesz to sobie wyobrazić? Mój wnuk... wygląda dokładnie jak mój syn!~
@10053  = ~Twój syn? Chyba chciałaś powiedzieć, że jest podobny do twojej córki?~
@10054  = ~Co masz na myśli?~
@10055  = ~Zatem wszystko skończyło się pomyślnie?~
@10056  = ~Mniejsza z tym, nie interesują mnie twoje problemy.~
@10057  = ~Nie, nie... mój SYN.~
@10058  = ~Rozumiem. Tak czy inaczej, chciałam, żebyś się o tym dowiedział. Masz dobre serce, nawet jeśli nie zawsze dajesz to po sobie poznać.~ ~Rozumiem. Tak czy inaczej, chciałam, żebyś się o tym dowiedziała. Masz dobre serce, nawet jeśli nie zawsze dajesz to po sobie poznać.~
@10059  = ~O tak. Wszystko zakończyło się pomyślnie!~
@10060  = ~Mój kochany, mały Joeffrey, który zmarł na odrę, gdy miał dziesięć lat... Ja... Spójrz tylko na tego chłopca! Te same wielkie, szare oczy, te same ciemnobrązowe włosy... On...~
@10061  = ~Ten chłopiec jest z mojej krwi i kości. To mój wnuk!... Ja... dziękuję, że pomogłeś mi go odnaleźć, panie. DZIĘKUJĘ ci.~ ~Ten chłopiec jest z mojej krwi i kości. To mój wnuk!... Ja... dziękuję, że pomogłaś mi go odnaleźć, pani. DZIĘKUJĘ ci.~
@10062  = ~Babciu? Narysowałem coś dla ciebie.~
@10063  = ~Och, jak ślicznie... O, nie! Nic ci nie przyniosłam – wyobrażasz to sobie? A może... może pójdziemy na jarmark i kupimy wielką torbę cukrowanych migdałów, hm?~
@10064  = ~Och, uwielbiam migdały!~
@10065  = ~A ten rysunek jest dla ciebie! Jesteś nieustraszonym poszukiwaczem przygód, prawda?~ ~A ten rysunek jest dla ciebie! Jesteś nieustraszoną poszukiwaczką przygód, prawda?~
@10066  = ~W takim razie chodźmy, Larsie! Kierunek jarmark!~
@10067  = ~Hura!~
@10068  = ~Mówię o moim SYNU.~
/*
@10069  = 
@10070  = 
*/

/* Tower Guards, "Doppelgangers Inside the Seatower" quest */
@10071  = ~Wszyssscy ssą w kossszarach... Ciekawe po sssso.~
@10072  = ~Sssso tam słychać?~
@10073  = ~Zjadłbym jakąś rybkę... Zapach morza ssssprawia, że robię sssię głodny.~
@10074  = ~Sssso ten mag ssssobie myśli? Że nasss przestrassszy?~
@10075  = ~Dossstaniemy nagrodę, kiedy to sssię sssskończy.~
@10076  = ~Mussssimy uważać na cywilów!~
@10077  = ~Odsuń się, obywatelu! To zadanie dla straży.~
@10078  = ~Chronić cywilów!~
@10079  = ~Coś tu zdecydowanie śmierdzi.~
@10080  = ~Rzadko się zdarza, by mistrz Shizell zaglądał do koszar. Na pewno coś się święci.~
@10081  = ~Może dostaniemy podwyżkę, gdy to wszystko się skończy.~
@10082  = ~Kapitan jest ostatnio dość drażliwy.~
@10083  = ~Ssssssss...~

/* z_quest_doppelgangers.d */
@10100  = ~Och... Och! Jakie to SŁODKIE! <CHARNAME>, możemy go zatrzymać? Proszę! No prooooszę! Jeśli go dobrze wytresujemy, mógłby wyjadać szczury ze stodół... albo coś w tym stylu.~
@10101  = ~Imoen, nie ośmieszaj się. Mimiki to potwory najgorszego sortu – są skrajnie podstępne i nie dają się oswoić. Pewnego dnia to stworzenie i tak wyrośnie na sobowtórniaka.~
@10102  = ~<CHARNAME>, nie daj się zwieść rzekomej łagodności tego mimika. Musimy go zgładzić, choćby po to, by chronić niewinnych ludzi.~
@10103  = ~Ojej... jest po prostu zbyt słodki. No dobrze, w porządku, rozumiem – musimy go zabić, bo jest groźny, bla, bla, bla... Ale i tak wielka szkoda!~

/* zz_quest_fireelemental.d */
@10250  = ~Och, spójrzcie na niego! Wygląda niemal na smutnego. Naprawdę musimy go zabijać?~
@10251  = ~Żywiołak ognia w piwnicy pełnej drewnianych beczek i skrzyń! Nie możemy na to pozwolić.~
@10252  = ~Przede wszystkim nie możemy pozwolić, żeby zbliżył się do beczek z dobrym piwem.~
@10253  = ~Żywiołaki ognia nie są złe. Gdybyśmy użyli ognioodpornego naczynia, moglibyśmy umieścić go z powrotem w wielkim płomieniu, by mógł wrócić do swojej Sfery.~
@10254  = ~Kucharka zdaje się mieć rację – on nie przetrwa długo w wilgotnej piwnicy. Choć trzeba przyznać, że temu miejscu dobrze zrobi odrobina osuszenia.~


/* Sahuagin Scout in Seatower Prison */
@10999  = ~Odg! Kla odg gul! Hrrrghh!~


//******************
// Skript lines
//******************

@11000  = ~Ten grobowiec jest pusty.~
@11001  = ~Zakłóciliście spokój zmarłych!~
@11002  = ~Znajdujesz w grobowcu jakiś drobiazg.~
@11003  = ~W tym grobowcu niczego nie znajdujesz.~
@11004  = ~Z wnętrza twierdzy dobiega słaby głos wołający o pomoc.~
@11005  = ~Naprawdę? Teraz?~
@11006  = ~Wyjście blokuje spory głaz, który wydaje się jednak obluzowany. Możesz spróbować przepchnąć go na drugą stronę.~
@11007  = ~Jesteś zbyt daleko, by móc coś tutaj zdziałać.~
@11008  = ~Popychasz głaz, aż w końcu ustępuje, pozostawiając wąskie przejście. Po drugiej stronie panuje mrok, ale słychać szum fal i czuć zapach morza.~
@11009  = ~W kącie jest wilgotno i połowę ściany pokryła niewielka kolonia zarodników.~
@11010  = ~Niszczysz wrogą kolonię zarodników, odsłaniając przejście ukryte w murach.~
@11011  = ~Tunel jest zawalony skałami i gruzem.~
@11012  = ~Woda w sadzawce jest przejrzysta i zdaje się lśnić błękitnym blaskiem.~
@11013  = ~Wiedząc już, czego szukać, dostrzegasz tajne wyjście do jaskiń morskich.~
@11014  = ~To najwyraźniej ten kąt, o którym wspomniał żołnierz. Połowę ściany pokrywa niewielka kolonia zarodników. Aby mieć pewność, że nie pojawi się więcej wrogich mykonidów, należy ją zniszczyć. Bez trudu zrobisz to za pomocą broni.~
@11015  = ~Pod cienką warstwą ziemi znajdujesz zwłoki sierżanta. Ma na sobie insygnia adiutanta dowódcy.~
@11016  = ~W stercie ziemi niczego nie ma.~
@11017  = ~W płytkiej wodzie przy brzegu sadzawki spoczywa małża niezwykłych rozmiarów. Możesz spróbować podważyć jej skorupę.~
@11018  = ~Otwierasz małża. W środku znajduje się ogromna czarna perła!~
@11019  = ~Zabierasz perłę i chowasz ją do plecaka.~
@11020  = ~Muszla jest pusta.~
@11021  = ~Aaaaaaaachhhh!~
@11022  = ~Opary „Pyłu mimika” spowiły teren Wieży, lecz nie ujawniły kolejnych potworów. Wygląda na to, że wybiłeś już wszystkie sobowtórniaki.~ ~Opary „Pyłu mimika” spowiły teren Wieży, lecz nie ujawniły kolejnych potworów. Wygląda na to, że wybiłaś już wszystkie sobowtórniaki.~
@11023  = ~Gdy tylko zdejmujesz pokrywę, z otchłani uderza cię ostry, gryzący smród.~
@11024  = ~Ogień latarni huczy z niespożytą siłą, wydając z siebie potężny ryk.~
@11025  = ~Wrzucasz beczkę z żywiołakiem wprost w ogień latarni, uwalniając uwięzioną w niej istotę.~
@11026  = ~Mogę włożyć patyk do ognia?~
@11027  = ~Nie, trzymaj się z dala od latarni. To niebezpieczne.~
@11028  = ~Musicie codziennie dolewać oliwy?~
@11029  = ~Robimy to regularnie, ale przy obecnych zapasach ogień płonąłby przez tydzień.~
@11030  = ~Ten płomień się poruszył! Przysięgam!~
@11031  = ~Wielkie paleniska zawsze przyciągają żywiołaki ognia. Jesteśmy tu po to, by pilnować, żeby z niego nie wychodziły.~
@11032  = ~Ooooch.~
@11033  = ~A nie moglibyście po prostu użyć jednego wielkiego żywiołaka zamiast całego tego drewna?~
@11034  = ~To byłoby zbyt niebezpieczne... i niepewne. Latarnia musi dawać stały blask, bo inaczej statki pobłądzą.~
@11035  = ~To prawda, że ten ogień widać ze statków daleko na morzu?~
@11036  = ~Tak, właśnie po to płonie. Dzięki niemu wiedzą, w którą stronę płynąć do miasta.~
@11037  = ~To prawda, że ten ogień widać aż z Tethyru?~
@11038  = ~Hm... to chyba jednak za daleko.~
@11039  = ~Musiałeś walczyć z wieloma takimi żywiołakami?~
@11040  = ~Zadajesz mnóstwo pytań. Hmm, przez te wszystkie lata nazbierało się może z pięć? Naprawdę rzadko się zdarza, by opuszczały płomienie.~
@11041  = ~Młodzieńcze, męczymy tego żołnierza już wystarczająco długo. Musimy iść. Podziękuj panu za cierpliwość.~
@11042  = ~Dziękuję!~
@11043  = ~Gotowe, drzwi otwarte. Tylko pilnujcie, żeby to coś nie wślizgnęło się do kuchni!~
@11044  = ~Mamo, mogę wrzucić złotą monetę? Proszę! No prooooszę!~
@11045  = ~Ja też! Ja też!~
@11046  = ~No dobrze, trzymajcie. Pomyślcie teraz życzenie!~
@11047  = ~*plusk*~
@11048  = ~O co poprosiłeś?~
@11049  = ~Nie wolno mówić! Jak powiesz, to się nie spełni!~
@11050  = ~Mamo, możemy wrzucić jeszcze jedną?~
@11051  = ~Nie, skarbie. Lepiej wydać te pieniądze na miodownik, co?~
@11052  = ~Miodownik! Chcę miodownika!~
@11053  = ~Kochanie, idziesz? Wejdziemy do środka.~
@11054  = ~*chlup*~
@11055  = ~Och, co to było? Kamień? Uważaj, żebyś nie rozgniewał ducha studni, bo wyjdzie i cię porwie!~
@11056  = ~*piiiszczy* Duch?! To straszne!~
@11057  = ~A czy duch też kupuje sobie miodowniki za nasze pieniądze?~
@11058  = ~Wątpię, słoneczko. Chodźmy już.~
@11059  = ~Już idę!~
@11060  = ~Zablokować port?~
@11061  = ~Tym łańcuchem?~
@11062  = ~Tylko wodorosty? Nie znajdujecie też żadnych ładnych muszelek?~
@11063  = ~Tak, muszle też. Ale rzadko ładne. Najgorzej usuwa się te, które przywierają do ogniw.~
@11064  = ~A wciągnęliście kiedyś delfina?~
@11065  = ~Uhm, nie.~
@11066  = ~Aaaaach.~
@11067  = ~Rose! Co to za pytanie. Proszę nam wybaczyć, panie.~
@11068  = ~Nie ma problemu, pani. Sam mam w domu takiego malucha.~
@11069  = ~Nie, poczekam tutaj.~
@11070  = ~*wzdycha*~
@11071  = ~To tylko bajka, kochanie, nie masz się czym martwić.~
@11072  = ~Po co właściwie jest ten łańcuch?~
@11073  = ~Ech, gdybym tylko mógł się z kimś zamienić! Jak mam niby szukać, skoro utknąłem tutaj na amen.~
@11074  = ~*wzdycha* Mam nadzieję, że u niej wszystko dobrze.~
@11075  = ~Zazwyczaj nie znika na tak długo. Nieważne, co opowiada ten opat!~
@11076  = ~Tak bym chciał móc z kimś o tym porozmawiać!~

